{
  "schema": 1,
  "runtime": {
    "rootfsPath": "/data/local/pixel-stack/chroots/adguardhome",
    "baseDir": "/data/local/pixel-stack",
    "controlMode": "local-su",
    "bootMode": "android-dual-path"
  },
  "dns": {
    "dnsPort": 53,
    "webPort": 8080,
    "precutoverPort": 5353,
    "dohBackend": "dnscrypt-proxy",
    "dohPort": 5053,
    "dohUpstream1": "https://1.1.1.1/dns-query",
    "dohUpstream2": "https://1.0.0.1/dns-query",
    "testDomain": "example.com"
  },
  "remote": {
    "dohEnabled": true,
    "dotEnabled": false,
    "dotIdentityEnabled": false,
    "dotIdentityLabelLength": 20,
    "hostname": "dns.jolkins.id.lv",
    "dotHostname": "dns.jolkins.id.lv",
    "httpsPort": 443,
    "dotPort": 853,
    "dotMaxConnPerIp": 20,
    "dotProxyTimeoutSeconds": 15,
    "dohInternalPort": 8053,
    "dohPathToken": "jolkins-doh-token-change-me",
    "adminEnabled": true,
    "adminUsername": "pihole",
    "adminPasswordFile": "/data/local/pixel-stack/conf/adguardhome/remote-admin-password",
    "ipinfoLiteTokenFile": "/data/local/pixel-stack/conf/adguardhome/ipinfo-lite-token",
    "adminAllowCidrs": "0.0.0.0/0",
    "acmeEnabled": true,
    "acmeEmail": "",
    "acmeCfTokenFile": "/data/local/pixel-stack/conf/ddns/cloudflare-token",
    "acmeRenewMinDays": 30,
    "dohRateLimitRps": 20,
    "watchdogEnabled": true,
    "watchdogEscalateRuntimeRestart": false,
    "watchdogIntervalSeconds": 30,
    "watchdogFails": 2,
    "watchdogCooldownSeconds": 120
  },
  "ssh": {
    "bindAddress": "0.0.0.0",
    "port": 2222,
    "authMode": "key_password",
    "passwordAuthEnabled": true,
    "keepAliveSeconds": 30,
    "idleTimeoutSeconds": 0,
    "receiveWindowBytes": 262144,
    "wifiForceLowLatencyMode": true,
    "wifiForceHiPerfMode": false,
    "maxRapidRestarts": 5,
    "rapidWindowSeconds": 300,
    "backoffInitialSeconds": 5,
    "backoffMaxSeconds": 60,
    "dropbearRootDir": "/data/local/pixel-stack/ssh",
    "authorizedKeysSourceFile": "/data/local/pixel-stack/conf/ssh/authorized_keys",
    "passwordHashSourceFile": "/data/local/pixel-stack/conf/ssh/root_password.hash"
  },
  "vpn": {
    "enabled": false,
    "runtimeRoot": "/data/local/pixel-stack/vpn",
    "authKeyFile": "/data/local/pixel-stack/conf/vpn/tailscale-authkey",
    "interfaceName": "tailscale0",
    "hostname": "",
    "advertiseTags": "",
    "acceptRoutes": false,
    "acceptDns": false,
    "maxRapidRestarts": 5,
    "rapidWindowSeconds": 300,
    "backoffInitialSeconds": 5,
    "backoffMaxSeconds": 60
  },
  "trainBot": {
    "runtimeRoot": "/data/local/pixel-stack/apps/train-bot",
    "envFile": "/data/local/pixel-stack/conf/apps/train-bot.env",
    "binaryPath": "/data/local/pixel-stack/apps/train-bot/bin/train-bot.current",
    "scheduleDir": "/data/local/pixel-stack/apps/train-bot/data/schedules",
    "publicBaseUrl": "https://train-bot.jolkins.id.lv",
    "ingressMode": "cloudflare_tunnel",
    "tunnelName": "train-bot",
    "tunnelCredentialsFile": "/data/local/pixel-stack/conf/apps/train-bot-cloudflared.json",
    "maxRapidRestarts": 5,
    "rapidWindowSeconds": 300,
    "backoffInitialSeconds": 5,
    "backoffMaxSeconds": 60
  },
  "satiksmeBot": {
    "runtimeRoot": "/data/local/pixel-stack/apps/satiksme-bot",
    "envFile": "/data/local/pixel-stack/conf/apps/satiksme-bot.env",
    "binaryPath": "/data/local/pixel-stack/apps/satiksme-bot/bin/satiksme-bot.current",
    "publicBaseUrl": "https://satiksme-bot.jolkins.id.lv",
    "ingressMode": "cloudflare_tunnel",
    "tunnelName": "satiksme-bot",
    "tunnelCredentialsFile": "/data/local/pixel-stack/conf/apps/satiksme-bot-cloudflared.json",
    "maxRapidRestarts": 5,
    "rapidWindowSeconds": 300,
    "backoffInitialSeconds": 5,
    "backoffMaxSeconds": 60
  },
  "siteNotifier": {
    "runtimeRoot": "/data/local/pixel-stack/apps/site-notifications",
    "envFile": "/data/local/pixel-stack/conf/apps/site-notifications.env",
    "pythonPath": "/data/local/pixel-stack/apps/site-notifications/bin/site-notifier-python.current",
    "entryScript": "/data/local/pixel-stack/apps/site-notifications/current/app.py",
    "maxRapidRestarts": 5,
    "rapidWindowSeconds": 300,
    "backoffInitialSeconds": 5,
    "backoffMaxSeconds": 60
  },
  "ddns": {
    "enabled": true,
    "provider": "cloudflare",
    "intervalSeconds": 120,
    "requireStableReads": 2,
    "ttl": 120,
    "zoneName": "jolkins.id.lv",
    "recordName": "dns.jolkins.id.lv",
    "updateIpv4": true,
    "updateIpv6": false,
    "tokenFile": "/data/local/pixel-stack/conf/ddns/cloudflare-token",
    "ipv4DiscoveryUrls": "https://api.ipify.org?format=json,https://checkip.amazonaws.com,https://ipv4.icanhazip.com",
    "ipv6DiscoveryUrls": "https://api64.ipify.org?format=json,https://ipv6.icanhazip.com"
  },
  "supervision": {
    "healthPollSeconds": 15,
    "enforceRemoteListeners": true,
    "unhealthyFails": 3,
    "maxRapidRestarts": 5,
    "rapidWindowSeconds": 300,
    "backoffInitialSeconds": 5,
    "backoffMaxSeconds": 60
  },
  "features": {
    "remoteClientPackEnabled": true,
    "windowsDohRefreshEnabled": true
  },
  "modules": {
    "dns": {
      "enabled": true
    },
    "ssh": {
      "enabled": true
    },
    "vpn": {
      "enabled": true
    },
    "ddns": {
      "enabled": true
    },
    "remote": {
      "enabled": true
    },
    "train_bot": {
      "enabled": true
    },
    "satiksme_bot": {
      "enabled": true
    },
    "site_notifier": {
      "enabled": true
    }
  },
  "observability": {
    "enabled": true,
    "runIdEnvVar": "PIXEL_RUN_ID",
    "eventOutputDir": "/data/local/pixel-stack/logs/events",
    "evidenceRoot": "/data/local/pixel-stack/logs/evidence"
  }
}
