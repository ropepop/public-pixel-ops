{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pixel-ops.local/schemas/module-manifest.v1.schema.json",
  "title": "Pixel Ops Module Manifest v1",
  "type": "object",
  "required": ["schema", "module_id", "owner", "runtime", "components"],
  "properties": {
    "schema": { "type": "integer", "const": 1 },
    "module_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_\\-]{1,63}$"
    },
    "owner": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "runtime": {
      "type": "object",
      "required": ["type", "healthcheck"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["service", "job", "synthetic_health", "external"]
        },
        "healthcheck": { "type": "string" },
        "run_id_env": { "type": "string", "default": "PIXEL_RUN_ID" }
      },
      "additionalProperties": true
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "start", "stop", "health", "redeploy"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z][a-z0-9_\\-]{1,63}$" },
          "start": { "type": "string" },
          "stop": { "type": "string" },
          "health": { "type": "string" },
          "restart": { "type": "string" },
          "redeploy": {
            "type": "object",
            "required": ["mode"],
            "properties": {
              "mode": {
                "type": "string",
                "enum": ["artifact_release", "asset_refresh", "job", "derived"]
              },
              "artifact_id": { "type": "string", "minLength": 1 },
              "derived_from": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_\\-]{1,63}$"
              },
              "release_root": { "type": "string", "minLength": 1 }
            },
            "allOf": [
              {
                "if": {
                  "properties": {
                    "mode": { "const": "artifact_release" }
                  }
                },
                "then": {
                  "required": ["artifact_id"]
                }
              },
              {
                "if": {
                  "properties": {
                    "mode": { "const": "derived" }
                  }
                },
                "then": {
                  "required": ["derived_from"]
                }
              }
            ],
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "observability": {
      "type": "object",
      "properties": {
        "event_source": { "type": "string" },
        "evidence_root": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
