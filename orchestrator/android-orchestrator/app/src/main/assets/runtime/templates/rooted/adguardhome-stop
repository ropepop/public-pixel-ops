#!/bin/bash
set -euo pipefail

export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH:-}"
hash -r >/dev/null 2>&1 || true

ADGUARDHOME_PID_FILE="/run/pixel-stack-adguardhome.pid"
REMOTE_WATCHDOG_PID_FILE="/run/pixel-stack-adguardhome-remote-watchdog.pid"
REMOTE_NGINX_PID_FILE="/run/pixel-stack-adguardhome-remote-nginx.pid"
REMOTE_DOH_IDENTITY_WEB_PID_FILE="/run/pixel-stack-adguardhome-doh-identity-web.pid"

kill_pidfile() {
  local file="$1"
  [[ -f "${file}" ]] || return 0
  local pid
  pid="$(cat "${file}" 2>/dev/null || true)"
  if [[ -n "${pid}" ]] && kill -0 "${pid}" >/dev/null 2>&1; then
    kill "${pid}" >/dev/null 2>&1 || true
    sleep 1
    kill -9 "${pid}" >/dev/null 2>&1 || true
  fi
  rm -f "${file}"
}

kill_pidfile "${REMOTE_WATCHDOG_PID_FILE}"
kill_pidfile "${REMOTE_NGINX_PID_FILE}"
kill_pidfile "${REMOTE_DOH_IDENTITY_WEB_PID_FILE}"
kill_pidfile "${ADGUARDHOME_PID_FILE}"

pkill -f 'adguardhome-remote-watchdog' >/dev/null 2>&1 || true
pkill -f 'adguardhome-doh-gateway' >/dev/null 2>&1 || true
pkill -f 'adguardhome-doh-identity-web.py' >/dev/null 2>&1 || true
pkill -f 'pixel-stack-adguardhome-remote-nginx.conf' >/dev/null 2>&1 || true
pkill -f 'AdGuardHome' >/dev/null 2>&1 || true
