#!/system/bin/sh
set -eu

BASE_DIR="${PIHOLE_BASE_DIR:-/data/local/pixel-stack}"
ENV_FILE="${BASE_DIR}/conf/adguardhome.env"
RUN_DIR="${BASE_DIR}/run"
LOG_DIR="${BASE_DIR}/logs"
SERVICE_LOG="${LOG_DIR}/adguardhome-service-loop.log"
RUNTIME_LOG="${LOG_DIR}/adguardhome-runtime.log"
HOST_PID_FILE="${RUN_DIR}/adguardhome-host.pid"
LOCK_DIR="${RUN_DIR}/adguardhome-service-loop.lock"
SERVICE_LOOP_NAME="adguardhome-service-loop"
SERVICE_LOOP_SELF="${BASE_DIR}/bin/${SERVICE_LOOP_NAME}"
SERVICE_LOOP_PID_FILE="${RUN_DIR}/${SERVICE_LOOP_NAME}.pid"
PREPARE_BIN="/usr/local/bin/adguardhome-render-config"
LAUNCH_CORE_BIN="/usr/local/bin/adguardhome-launch-core"
LAUNCH_FRONTEND_BIN="/usr/local/bin/adguardhome-launch-frontend"
START_BIN="/usr/local/bin/adguardhome-start"
RESOLVER_RUNTIME_START_EPOCH_FILE="${RUN_DIR}/pixel-stack-adguardhome-runtime-start-epoch"
RESOLVER_LAST_EXIT_REASON_FILE="${RUN_DIR}/pixel-stack-adguardhome-last-exit-reason"
RESOLVER_LAST_EXIT_EPOCH_FILE="${RUN_DIR}/pixel-stack-adguardhome-last-exit-epoch"
RESOLVER_LAST_STABLE_RUNTIME_SEC_FILE="${RUN_DIR}/pixel-stack-adguardhome-last-stable-runtime-sec"
RESOLVER_RESTART_COUNT_FILE="${RUN_DIR}/pixel-stack-adguardhome-restart-count"
RESOLVER_RESTART_WINDOW_EPOCH_FILE="${RUN_DIR}/pixel-stack-adguardhome-restart-window-epoch"
RESOLVER_RESTART_COUNT_1H_FILE="${RUN_DIR}/pixel-stack-adguardhome-restart-count-1h"

mkdir -p "${RUN_DIR}" "${LOG_DIR}"

ts() {
  date '+%Y-%m-%dT%H:%M:%S%z'
}

log() {
  printf '[%s] %s\n' "$(ts)" "$*" >> "${SERVICE_LOG}"
}

write_state_file() {
  local file="$1" value="${2:-}" tmpfile=""
  mkdir -p "$(dirname "${file}")"
  tmpfile="${file}.tmp.$$"
  printf '%s\n' "${value}" > "${tmpfile}"
  chmod 600 "${tmpfile}" >/dev/null 2>&1 || true
  mv -f "${tmpfile}" "${file}"
}

read_state_int() {
  local file="$1" value=""
  [ -r "${file}" ] || return 1
  value="$(tr -d '\r\n[:space:]' < "${file}" 2>/dev/null || true)"
  case "${value}" in
    ''|*[!0-9]*) return 1 ;;
  esac
  printf '%s\n' "${value}"
}

record_runtime_start() {
  write_state_file "${RESOLVER_RUNTIME_START_EPOCH_FILE}" "$(date +%s)"
}

record_runtime_restart() {
  local reason="$1" now_epoch start_epoch stable_runtime count window_epoch

  now_epoch="$(date +%s)"
  start_epoch="$(read_state_int "${RESOLVER_RUNTIME_START_EPOCH_FILE}" 2>/dev/null || true)"
  stable_runtime=0
  case "${start_epoch}" in
    ''|*[!0-9]*) ;;
    *)
      stable_runtime=$((now_epoch - start_epoch))
      if [ "${stable_runtime}" -lt 0 ]; then
        stable_runtime=0
      fi
      ;;
  esac
  write_state_file "${RESOLVER_LAST_STABLE_RUNTIME_SEC_FILE}" "${stable_runtime}"

  count="$(read_state_int "${RESOLVER_RESTART_COUNT_FILE}" 2>/dev/null || printf '0')"
  count=$((count + 1))
  write_state_file "${RESOLVER_RESTART_COUNT_FILE}" "${count}"

  window_epoch="$(read_state_int "${RESOLVER_RESTART_WINDOW_EPOCH_FILE}" 2>/dev/null || true)"
  case "${window_epoch}" in
    ''|*[!0-9]*)
      write_state_file "${RESOLVER_RESTART_WINDOW_EPOCH_FILE}" "${now_epoch}"
      write_state_file "${RESOLVER_RESTART_COUNT_1H_FILE}" "1"
      ;;
    *)
      if [ $((now_epoch - window_epoch)) -ge 3600 ]; then
        write_state_file "${RESOLVER_RESTART_WINDOW_EPOCH_FILE}" "${now_epoch}"
        write_state_file "${RESOLVER_RESTART_COUNT_1H_FILE}" "1"
      else
        count="$(read_state_int "${RESOLVER_RESTART_COUNT_1H_FILE}" 2>/dev/null || printf '0')"
        count=$((count + 1))
        write_state_file "${RESOLVER_RESTART_COUNT_1H_FILE}" "${count}"
      fi
      ;;
  esac

  write_state_file "${RESOLVER_LAST_EXIT_REASON_FILE}" "${reason}"
  write_state_file "${RESOLVER_LAST_EXIT_EPOCH_FILE}" "${now_epoch}"
}

is_true() {
  case "${1:-}" in
    1|true|TRUE|yes|YES|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}

pid_is_running() {
  local pid="$1"
  [ -n "${pid}" ] && kill -0 "${pid}" >/dev/null 2>&1
}

runtime_adguard_pid() {
  local pid pid_file cmdline
  pid_file="${ADGUARDHOME_ROOTFS_PATH:-/data/local/pixel-stack/chroots/adguardhome}/run/pixel-stack-adguardhome.pid"
  pid="$(sed -n '1p' "${pid_file}" 2>/dev/null | tr -d '\r' || true)"
  case "${pid}" in
    ''|*[!0-9]*) return 1 ;;
  esac
  pid_is_running "${pid}" || return 1
  cmdline="$(pid_cmdline "${pid}" || true)"
  case "${cmdline}" in
    *AdGuardHome*) ;;
    *) return 1 ;;
  esac
  printf '%s\n' "${pid}"
}

log_runtime_tail() {
  [ -f "${RUNTIME_LOG}" ] || return 0
  tail -n 20 "${RUNTIME_LOG}" 2>/dev/null | while IFS= read -r line; do
    [ -n "${line}" ] || continue
    log "runtime-tail: ${line}"
  done
}

pid_cmdline() {
  local pid="$1"
  if [ -r "/proc/${pid}/cmdline" ]; then
    tr '\000' ' ' < "/proc/${pid}/cmdline" 2>/dev/null || true
    return 0
  fi
  if command -v ps >/dev/null 2>&1; then
    ps -p "${pid}" -o command= 2>/dev/null || true
    return 0
  fi
  return 1
}

pid_matches_service_loop() {
  local pid="$1" cmdline=""
  if [ -z "${pid}" ] || ! pid_is_running "${pid}"; then
    return 1
  fi
  case "${pid}" in
    ''|*[!0-9]*) return 1 ;;
  esac
  cmdline="$(pid_cmdline "${pid}" || true)"
  if [ -z "${cmdline}" ]; then
    return 1
  fi
  case " ${cmdline} " in
    *" ${SERVICE_LOOP_SELF} "*|*" ${SERVICE_LOOP_NAME} "*) return 0 ;;
    *) return 1 ;;
  esac
}

acquire_loop_lock() {
  local pid=""
  if mkdir "${LOCK_DIR}" >/dev/null 2>&1; then
    return 0
  fi

  pid="$(sed -n '1p' "${SERVICE_LOOP_PID_FILE}" 2>/dev/null | tr -d '\r' || true)"
  if pid_matches_service_loop "${pid}"; then
    log "another ${SERVICE_LOOP_NAME} instance is already running (pid=${pid})"
    return 1
  fi

  log "stale ${SERVICE_LOOP_NAME} lock detected; resetting lock state"
  rm -f "${SERVICE_LOOP_PID_FILE}" >/dev/null 2>&1 || true
  rmdir "${LOCK_DIR}" >/dev/null 2>&1 || true
  if mkdir "${LOCK_DIR}" >/dev/null 2>&1; then
    return 0
  fi

  log "unable to acquire ${SERVICE_LOOP_NAME} lock; exiting"
  return 1
}

release_loop_lock() {
  rm -f "${SERVICE_LOOP_PID_FILE}" >/dev/null 2>&1 || true
  rmdir "${LOCK_DIR}" >/dev/null 2>&1 || true
}

port_tcp_listening() {
  local port="$1"
  if command -v ss >/dev/null 2>&1; then
    ss -ltn 2>/dev/null | awk -v port="${port}" '
      NR > 1 {
        local_addr=$4
        if (local_addr ~ ("[.:]" port "$")) {
          found=1
          exit 0
        }
      }
      END { exit(found ? 0 : 1) }
    '
    return $?
  fi
  if command -v netstat >/dev/null 2>&1; then
    netstat -ltn 2>/dev/null | awk -v port="${port}" '
      NR > 2 {
        local_addr=$4
        if (local_addr ~ ("[.:]" port "$")) {
          found=1
          exit 0
        }
      }
      END { exit(found ? 0 : 1) }
    '
    return $?
  fi
  return 1
}

mount_is_present() {
  local target="$1"
  grep -F " ${target} " /proc/mounts >/dev/null 2>&1
}

load_runtime_env() {
  if [ -r "${ENV_FILE}" ]; then
    # shellcheck disable=SC1090
    set -a
    . "${ENV_FILE}"
    set +a
  fi

  : "${ADGUARDHOME_ROOTFS_PATH:=/data/local/pixel-stack/chroots/adguardhome}"
  : "${PIHOLE_DNS_PORT:=53}"
  : "${PIHOLE_ACTIVE_DNS_PORT:=${PIHOLE_DNS_PORT}}"
  : "${PIHOLE_WEB_PORT:=8080}"
  : "${PIHOLE_REMOTE_DOH_ENABLED:=0}"
  : "${PIHOLE_REMOTE_DOT_ENABLED:=0}"
  : "${ADGUARDHOME_REMOTE_ADMIN_ENABLED:=1}"
  : "${PIHOLE_REMOTE_HTTPS_PORT:=443}"
  : "${PIHOLE_REMOTE_DOT_PORT:=853}"
  : "${PIHOLE_REMOTE_DOH_IDENTITY_WEB_PORT:=8097}"
  : "${PIHOLE_REMOTE_DOH_IDENTITY_WEB_PID_FILE:=/run/pixel-stack-adguardhome-doh-identity-web.pid}"

  : "${PIHOLE_SERVICE_HEALTH_POLL_SEC:=15}"
  : "${PIHOLE_SERVICE_UNHEALTHY_FAILS:=3}"
  : "${PIHOLE_SERVICE_MAX_RAPID_RESTARTS:=5}"
  : "${PIHOLE_SERVICE_RAPID_WINDOW_SECONDS:=300}"
  : "${PIHOLE_SERVICE_BACKOFF_SECONDS:=5}"
  : "${PIHOLE_SERVICE_BACKOFF_MAX_SECONDS:=60}"
  : "${PIHOLE_SERVICE_ENFORCE_REMOTE_LISTENERS:=1}"

  case "${PIHOLE_SERVICE_HEALTH_POLL_SEC}" in
    ''|*[!0-9]*) PIHOLE_SERVICE_HEALTH_POLL_SEC=15 ;;
  esac
  case "${PIHOLE_SERVICE_UNHEALTHY_FAILS}" in
    ''|*[!0-9]*) PIHOLE_SERVICE_UNHEALTHY_FAILS=3 ;;
  esac
  case "${PIHOLE_SERVICE_MAX_RAPID_RESTARTS}" in
    ''|*[!0-9]*) PIHOLE_SERVICE_MAX_RAPID_RESTARTS=5 ;;
  esac
  case "${PIHOLE_SERVICE_RAPID_WINDOW_SECONDS}" in
    ''|*[!0-9]*) PIHOLE_SERVICE_RAPID_WINDOW_SECONDS=300 ;;
  esac
  case "${PIHOLE_SERVICE_BACKOFF_SECONDS}" in
    ''|*[!0-9]*) PIHOLE_SERVICE_BACKOFF_SECONDS=5 ;;
  esac
  case "${PIHOLE_SERVICE_BACKOFF_MAX_SECONDS}" in
    ''|*[!0-9]*) PIHOLE_SERVICE_BACKOFF_MAX_SECONDS=60 ;;
  esac
  case "${PIHOLE_SERVICE_ENFORCE_REMOTE_LISTENERS}" in
    ''|*[!0-9]*) PIHOLE_SERVICE_ENFORCE_REMOTE_LISTENERS=1 ;;
  esac

  [ "${PIHOLE_SERVICE_HEALTH_POLL_SEC}" -ge 1 ] || PIHOLE_SERVICE_HEALTH_POLL_SEC=15
  [ "${PIHOLE_SERVICE_UNHEALTHY_FAILS}" -ge 1 ] || PIHOLE_SERVICE_UNHEALTHY_FAILS=3
  [ "${PIHOLE_SERVICE_MAX_RAPID_RESTARTS}" -ge 1 ] || PIHOLE_SERVICE_MAX_RAPID_RESTARTS=5
  [ "${PIHOLE_SERVICE_RAPID_WINDOW_SECONDS}" -ge 1 ] || PIHOLE_SERVICE_RAPID_WINDOW_SECONDS=300
  [ "${PIHOLE_SERVICE_BACKOFF_SECONDS}" -ge 1 ] || PIHOLE_SERVICE_BACKOFF_SECONDS=5
  [ "${PIHOLE_SERVICE_BACKOFF_MAX_SECONDS}" -ge "${PIHOLE_SERVICE_BACKOFF_SECONDS}" ] || PIHOLE_SERVICE_BACKOFF_MAX_SECONDS="${PIHOLE_SERVICE_BACKOFF_SECONDS}"
}

expect_https_listener() {
  if is_true "${PIHOLE_REMOTE_DOH_ENABLED}" || is_true "${PIHOLE_REMOTE_DOT_ENABLED}" || is_true "${ADGUARDHOME_REMOTE_ADMIN_ENABLED}"; then
    return 0
  fi
  return 1
}

runtime_ports_healthy() {
  local active_dns_port web_port

  active_dns_port="${PIHOLE_ACTIVE_DNS_PORT:-${PIHOLE_DNS_PORT:-53}}"
  web_port="${PIHOLE_WEB_PORT:-8080}"

  port_tcp_listening "${active_dns_port}" || return 1
  port_tcp_listening "${web_port}" || return 1

  return 0
}

runtime_remote_healthy() {
  if ! is_true "${PIHOLE_SERVICE_ENFORCE_REMOTE_LISTENERS}"; then
    return 0
  fi

  if ! expect_https_listener; then
    return 0
  fi

  run_chroot_helper "${START_BIN}" --remote-healthcheck
}

recover_remote_frontend() {
  if ! is_true "${PIHOLE_SERVICE_ENFORCE_REMOTE_LISTENERS}"; then
    return 0
  fi

  if ! expect_https_listener; then
    return 0
  fi

  log "attempting remote frontend recovery via adguardhome-start --remote-restart"
  if run_chroot_helper "${START_BIN}" --remote-restart; then
    log "remote frontend recovery succeeded"
    return 0
  fi

  log "remote frontend recovery failed"
  return 1
}

ensure_chroot_mounts_and_resolv() {
  mkdir -p "${ADGUARDHOME_ROOTFS_PATH}/proc" \
           "${ADGUARDHOME_ROOTFS_PATH}/sys" \
           "${ADGUARDHOME_ROOTFS_PATH}/dev" \
           "${ADGUARDHOME_ROOTFS_PATH}/dev/pts" \
           "${ADGUARDHOME_ROOTFS_PATH}/etc"

  mount_is_present "${ADGUARDHOME_ROOTFS_PATH}/proc" || mount -t proc proc "${ADGUARDHOME_ROOTFS_PATH}/proc"
  mount_is_present "${ADGUARDHOME_ROOTFS_PATH}/sys" || mount -t sysfs sysfs "${ADGUARDHOME_ROOTFS_PATH}/sys"
  mount_is_present "${ADGUARDHOME_ROOTFS_PATH}/dev" || mount -o bind /dev "${ADGUARDHOME_ROOTFS_PATH}/dev"
  mount_is_present "${ADGUARDHOME_ROOTFS_PATH}/dev/pts" || mount -o bind /dev/pts "${ADGUARDHOME_ROOTFS_PATH}/dev/pts"

  mkdir -p "${ADGUARDHOME_ROOTFS_PATH}/dev/shm"
  mount_is_present "${ADGUARDHOME_ROOTFS_PATH}/dev/shm" || mount -t tmpfs -o mode=1777,nosuid,nodev tmpfs "${ADGUARDHOME_ROOTFS_PATH}/dev/shm"

  if [ ! -s "${ADGUARDHOME_ROOTFS_PATH}/etc/resolv.conf" ]; then
    if [ -f /etc/resolv.conf ]; then
      cp /etc/resolv.conf "${ADGUARDHOME_ROOTFS_PATH}/etc/resolv.conf"
    else
      printf 'nameserver 1.1.1.1\n' > "${ADGUARDHOME_ROOTFS_PATH}/etc/resolv.conf"
    fi
  fi
}

run_chroot_helper() {
  helper="$1"
  shift || true
  (
    export PATH="/system/bin:/system/xbin:/vendor/bin:/apex/com.android.runtime/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
    export HOME="/root"
    exec /system/bin/chroot "${ADGUARDHOME_ROOTFS_PATH}" "${helper}" "$@"
  ) >> "${RUNTIME_LOG}" 2>&1
}

stop_runtime() {
  local pid="" adguard_pid=""
  if [ -f "${HOST_PID_FILE}" ]; then
    pid="$(cat "${HOST_PID_FILE}" 2>/dev/null || true)"
    if pid_is_running "${pid}"; then
      kill "${pid}" >/dev/null 2>&1 || true
      sleep 1
      kill -9 "${pid}" >/dev/null 2>&1 || true
    fi
  fi
  adguard_pid="$(runtime_adguard_pid 2>/dev/null || true)"
  if pid_is_running "${adguard_pid}"; then
    kill "${adguard_pid}" >/dev/null 2>&1 || true
    sleep 1
    kill -9 "${adguard_pid}" >/dev/null 2>&1 || true
  fi
  rm -f "${HOST_PID_FILE}"
}

start_runtime() {
  local pid=""
  ensure_chroot_mounts_and_resolv

  if ! run_chroot_helper "${PREPARE_BIN}"; then
    return 11
  fi
  if ! run_chroot_helper "${LAUNCH_CORE_BIN}"; then
    return 12
  fi

  pid="$(runtime_adguard_pid 2>/dev/null || true)"
  if ! pid_is_running "${pid}"; then
    return 13
  fi
  printf '%s\n' "${pid}" > "${HOST_PID_FILE}"
  record_runtime_start

  if ! run_chroot_helper "${LAUNCH_FRONTEND_BIN}"; then
    if is_true "${PIHOLE_SERVICE_ENFORCE_REMOTE_LISTENERS}" && expect_https_listener; then
      log "frontend launch failed after core startup while remote listener enforcement is enabled"
      if recover_remote_frontend; then
        return 0
      fi
      log_runtime_tail
      return 14
    fi
    log "frontend launch failed after core startup; keeping resolver online"
    log_runtime_tail
  fi
  if ! run_chroot_helper "${START_BIN}" --start-watchdog; then
    log "watchdog start failed; remote frontend recovery is degraded"
  fi
  if ! run_chroot_helper "${START_BIN}" --run-migration-import; then
    log "migration import did not complete during runtime start"
  fi

  if ! runtime_remote_healthy; then
    if is_true "${PIHOLE_SERVICE_ENFORCE_REMOTE_LISTENERS}" && expect_https_listener; then
      log "remote listener healthcheck failed after runtime startup"
      if recover_remote_frontend; then
        return 0
      fi
      log_runtime_tail
      return 15
    fi
  fi

  return 0
}

monitor_runtime_health() {
  local pid="$1" unhealthy_count=0 core_ok=0 remote_ok=0

  log "monitoring rooted AdGuardHome pid=${pid}"
  while pid_is_running "${pid}"; do
    core_ok=0
    remote_ok=0
    if runtime_ports_healthy; then
      core_ok=1
    fi
    if runtime_remote_healthy; then
      remote_ok=1
    fi

    if [ "${core_ok}" -eq 1 ] && [ "${remote_ok}" -eq 1 ]; then
      unhealthy_count=0
    else
      unhealthy_count=$((unhealthy_count + 1))
      if [ "${unhealthy_count}" -ge "${PIHOLE_SERVICE_UNHEALTHY_FAILS}" ]; then
        if [ "${core_ok}" -eq 1 ] && [ "${remote_ok}" -eq 0 ] && is_true "${PIHOLE_SERVICE_ENFORCE_REMOTE_LISTENERS}" && expect_https_listener; then
          log "remote listener health failed ${unhealthy_count}/${PIHOLE_SERVICE_UNHEALTHY_FAILS}; attempting frontend recovery"
          if recover_remote_frontend; then
            unhealthy_count=0
            continue
          fi
        fi
        log "listener health failed ${unhealthy_count}/${PIHOLE_SERVICE_UNHEALTHY_FAILS}; forcing restart"
        return 10
      fi
    fi
    sleep "${PIHOLE_SERVICE_HEALTH_POLL_SEC}"
  done

  log "rooted AdGuardHome process exited pid=${pid}"
  return 20
}

  if ! acquire_loop_lock; then
  exit 0
fi
echo "$$" > "${SERVICE_LOOP_PID_FILE}"
trap release_loop_lock EXIT HUP INT TERM

load_runtime_env

rapid_count=0
window_start="$(date +%s)"
backoff="${PIHOLE_SERVICE_BACKOFF_SECONDS}"

log "adguardhome-service-loop started"

while true; do
  load_runtime_env

  if [ ! -r "${ENV_FILE}" ]; then
    log "runtime env missing: ${ENV_FILE}"
  fi

  if [ ! -x "${ADGUARDHOME_ROOTFS_PATH}${PREPARE_BIN}" ] || \
     [ ! -x "${ADGUARDHOME_ROOTFS_PATH}${LAUNCH_CORE_BIN}" ] || \
     [ ! -x "${ADGUARDHOME_ROOTFS_PATH}${LAUNCH_FRONTEND_BIN}" ] || \
     [ ! -x "${ADGUARDHOME_ROOTFS_PATH}${START_BIN}" ]; then
    log "missing rooted runtime helper(s) in chroot under ${ADGUARDHOME_ROOTFS_PATH}/usr/local/bin"
  else
    pid="$(cat "${HOST_PID_FILE}" 2>/dev/null || true)"
    adguard_pid="$(runtime_adguard_pid 2>/dev/null || true)"
    if ! pid_is_running "${pid}" && pid_is_running "${adguard_pid}"; then
      log "adopting live AdGuard runtime pid=${adguard_pid}"
      pid="${adguard_pid}"
      printf '%s\n' "${pid}" > "${HOST_PID_FILE}"
      if ! read_state_int "${RESOLVER_RUNTIME_START_EPOCH_FILE}" >/dev/null 2>&1; then
        record_runtime_start
      fi
    fi
    if ! pid_is_running "${pid}"; then
      log "starting rooted AdGuardHome runtime"
      stop_runtime
      start_rc=0
      if start_runtime; then
        :
      else
        start_rc=$?
        case "${start_rc}" in
          11) reason="prepare-runtime-failed" ;;
          12) reason="launch-core-failed" ;;
          13) reason="missing-core-pid-after-launch" ;;
          14) reason="launch-frontend-failed" ;;
          15) reason="remote-healthcheck-failed-after-start" ;;
          *) reason="start-runtime-failed" ;;
        esac
        record_runtime_restart "${reason}"
        log "start failed: reason=${reason} rc=${start_rc}"
        log_runtime_tail
        case "${start_rc}" in
          14|15)
            log "stopping partially started runtime after remote frontend failure"
            stop_runtime
            ;;
        esac
      fi
      pid="$(cat "${HOST_PID_FILE}" 2>/dev/null || true)"
      adguard_pid="$(runtime_adguard_pid 2>/dev/null || true)"
      if pid_is_running "${adguard_pid}"; then
        pid="${adguard_pid}"
      fi
    fi

    if pid_is_running "${pid}"; then
      set +e
      monitor_runtime_health "${pid}"
      monitor_rc=$?
      set -e
      if [ "${monitor_rc}" -eq 10 ]; then
        record_runtime_restart "core-healthcheck-failed"
        stop_runtime
      fi
      if [ "${monitor_rc}" -eq 20 ]; then
        record_runtime_restart "core-process-exited"
      fi
      if [ "${monitor_rc}" -ne 10 ]; then
        log_runtime_tail
      fi
    fi
  fi

  now="$(date +%s)"
  if [ $((now - window_start)) -gt "${PIHOLE_SERVICE_RAPID_WINDOW_SECONDS}" ]; then
    window_start="${now}"
    rapid_count=0
    backoff="${PIHOLE_SERVICE_BACKOFF_SECONDS}"
  fi

  rapid_count=$((rapid_count + 1))
  if [ "${rapid_count}" -gt "${PIHOLE_SERVICE_MAX_RAPID_RESTARTS}" ]; then
    log "too many rapid restarts (${rapid_count}/${PIHOLE_SERVICE_MAX_RAPID_RESTARTS}), sleeping 120s"
    sleep 120
    window_start="$(date +%s)"
    rapid_count=0
    backoff="${PIHOLE_SERVICE_BACKOFF_SECONDS}"
    continue
  fi

  log "restarting loop cycle after ${backoff}s"
  sleep "${backoff}"
  if [ "${backoff}" -lt "${PIHOLE_SERVICE_BACKOFF_MAX_SECONDS}" ]; then
    backoff=$((backoff * 2))
    if [ "${backoff}" -gt "${PIHOLE_SERVICE_BACKOFF_MAX_SECONDS}" ]; then
      backoff="${PIHOLE_SERVICE_BACKOFF_MAX_SECONDS}"
    fi
  fi
done
