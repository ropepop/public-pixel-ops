#!/bin/bash
set -euo pipefail

RUNTIME_ENV_FILE="/etc/pixel-stack/remote-dns/runtime.env"
PID_FILE="/run/pixel-stack-adguardhome-remote-watchdog.pid"
LOG_FILE="/var/log/adguardhome/remote-watchdog.log"
PIHOLE_START_BIN="/usr/local/bin/adguardhome-start"

if [[ -r "${RUNTIME_ENV_FILE}" ]]; then
  # shellcheck disable=SC1090
  set -a; source "${RUNTIME_ENV_FILE}"; set +a
fi

PIHOLE_REMOTE_WATCHDOG_ENABLED="${PIHOLE_REMOTE_WATCHDOG_ENABLED:-1}"
PIHOLE_REMOTE_WATCHDOG_INTERVAL="${PIHOLE_REMOTE_WATCHDOG_INTERVAL:-30}"
PIHOLE_REMOTE_WATCHDOG_FAILS="${PIHOLE_REMOTE_WATCHDOG_FAILS:-2}"
PIHOLE_REMOTE_WATCHDOG_COOLDOWN="${PIHOLE_REMOTE_WATCHDOG_COOLDOWN:-120}"
PIHOLE_REMOTE_WATCHDOG_ESCALATE_RUNTIME="${PIHOLE_REMOTE_WATCHDOG_ESCALATE_RUNTIME:-0}"

ts() { date -u '+%Y-%m-%dT%H:%M:%SZ'; }
log() { printf '[%s] [watchdog] %s\n' "$(ts)" "$*" >> "${LOG_FILE}"; }

is_true() {
  case "${1:-}" in
    1|true|TRUE|yes|YES|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}

pid_is_running() {
  local pid="${1:-}"
  [[ -n "${pid}" ]] && kill -0 "${pid}" >/dev/null 2>&1
}

if ! is_true "${PIHOLE_REMOTE_WATCHDOG_ENABLED}"; then
  exit 0
fi

[[ "${PIHOLE_REMOTE_WATCHDOG_INTERVAL}" =~ ^[0-9]+$ ]] || PIHOLE_REMOTE_WATCHDOG_INTERVAL=30
[[ "${PIHOLE_REMOTE_WATCHDOG_FAILS}" =~ ^[0-9]+$ ]] || PIHOLE_REMOTE_WATCHDOG_FAILS=2
[[ "${PIHOLE_REMOTE_WATCHDOG_COOLDOWN}" =~ ^[0-9]+$ ]] || PIHOLE_REMOTE_WATCHDOG_COOLDOWN=120
(( PIHOLE_REMOTE_WATCHDOG_INTERVAL >= 1 )) || PIHOLE_REMOTE_WATCHDOG_INTERVAL=30
(( PIHOLE_REMOTE_WATCHDOG_FAILS >= 1 )) || PIHOLE_REMOTE_WATCHDOG_FAILS=2
(( PIHOLE_REMOTE_WATCHDOG_COOLDOWN >= 1 )) || PIHOLE_REMOTE_WATCHDOG_COOLDOWN=120

mkdir -p "$(dirname "${PID_FILE}")" "$(dirname "${LOG_FILE}")"

if [[ -f "${PID_FILE}" ]]; then
  old_pid="$(cat "${PID_FILE}" 2>/dev/null || true)"
  if pid_is_running "${old_pid}" && [[ "${old_pid}" != "$$" ]]; then
    log "already running (pid=${old_pid}); exiting duplicate watchdog"
    exit 0
  fi
fi

echo "$$" > "${PID_FILE}"
chmod 600 "${PID_FILE}" >/dev/null 2>&1 || true
trap 'rm -f "${PID_FILE}"' EXIT

if [[ ! -x "${PIHOLE_START_BIN}" ]]; then
  log "missing helper: ${PIHOLE_START_BIN}; exiting"
  exit 1
fi

consecutive_failures=0
last_escalation_epoch=0

log "started (interval=${PIHOLE_REMOTE_WATCHDOG_INTERVAL}s fails=${PIHOLE_REMOTE_WATCHDOG_FAILS} cooldown=${PIHOLE_REMOTE_WATCHDOG_COOLDOWN}s escalate_runtime=${PIHOLE_REMOTE_WATCHDOG_ESCALATE_RUNTIME})"

while true; do
  if "${PIHOLE_START_BIN}" --remote-healthcheck >/dev/null 2>&1; then
    consecutive_failures=0
  else
    consecutive_failures=$((consecutive_failures + 1))
    log "healthcheck failed (${consecutive_failures}/${PIHOLE_REMOTE_WATCHDOG_FAILS})"
    diagnostics="$({ "${PIHOLE_START_BIN}" --remote-healthcheck-debug 2>&1 || true; } | tr '\n' ';' | sed 's/;*$//')"
    if [[ -n "${diagnostics}" ]]; then
      log "healthcheck diagnostics: ${diagnostics}"
    fi
    if (( consecutive_failures >= PIHOLE_REMOTE_WATCHDOG_FAILS )); then
      log "performing targeted frontend reload"
      "${PIHOLE_START_BIN}" --remote-reload-frontend >/dev/null 2>&1 || true
      sleep 2
      if "${PIHOLE_START_BIN}" --remote-healthcheck >/dev/null 2>&1; then
        log "targeted frontend reload recovered remote listeners"
        consecutive_failures=0
      else
        if ! is_true "${PIHOLE_REMOTE_WATCHDOG_ESCALATE_RUNTIME}"; then
          log "frontend reload failed; runtime escalation disabled"
          sleep "${PIHOLE_REMOTE_WATCHDOG_INTERVAL}"
          continue
        fi
        if "${PIHOLE_START_BIN}" --core-healthcheck >/dev/null 2>&1; then
          log "frontend reload failed but core runtime is healthy; skipping runtime restart"
          sleep "${PIHOLE_REMOTE_WATCHDOG_INTERVAL}"
          continue
        fi
        now_epoch="$(date +%s)"
        if (( now_epoch - last_escalation_epoch >= PIHOLE_REMOTE_WATCHDOG_COOLDOWN )); then
          last_escalation_epoch="${now_epoch}"
          log "frontend reload failed; escalating to sidecar runtime restart"
          "${PIHOLE_START_BIN}" --runtime-restart-services >/dev/null 2>&1 || true
          sleep 3
          if "${PIHOLE_START_BIN}" --remote-healthcheck >/dev/null 2>&1; then
            log "sidecar runtime restart recovered remote listeners"
            consecutive_failures=0
          else
            log "remote stack still unhealthy after escalation"
          fi
        else
          log "cooldown active; skipping escalation"
        fi
      fi
    fi
  fi
  sleep "${PIHOLE_REMOTE_WATCHDOG_INTERVAL}"
done
