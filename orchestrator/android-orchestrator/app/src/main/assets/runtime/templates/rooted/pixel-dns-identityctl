#!/system/bin/sh
set -eu

BASE="/data/local/pixel-stack"
CONF_FILE="${BASE}/conf/adguardhome.env"
ROOTFS="/data/local/pixel-stack/chroots/adguardhome"
CHROOT_CTL="/usr/local/bin/adguardhome-doh-identityctl"

mount_is_present() {
  local target="$1"
  grep -F " ${target} " /proc/mounts >/dev/null 2>&1
}

ensure_chroot_mounts_and_resolv() {
  mkdir -p "${ROOTFS}/proc" \
           "${ROOTFS}/sys" \
           "${ROOTFS}/dev" \
           "${ROOTFS}/dev/pts" \
           "${ROOTFS}/etc"

  mount_is_present "${ROOTFS}/proc" || mount -t proc proc "${ROOTFS}/proc"
  mount_is_present "${ROOTFS}/sys" || mount -t sysfs sysfs "${ROOTFS}/sys"
  mount_is_present "${ROOTFS}/dev" || mount -o bind /dev "${ROOTFS}/dev"
  mount_is_present "${ROOTFS}/dev/pts" || mount -o bind /dev/pts "${ROOTFS}/dev/pts"

  mkdir -p "${ROOTFS}/dev/shm"
  mount_is_present "${ROOTFS}/dev/shm" || mount -t tmpfs -o mode=1777,nosuid,nodev tmpfs "${ROOTFS}/dev/shm"

  if [ ! -s "${ROOTFS}/etc/resolv.conf" ]; then
    if [ -f /etc/resolv.conf ]; then
      cp /etc/resolv.conf "${ROOTFS}/etc/resolv.conf"
    else
      printf 'nameserver 1.1.1.1\n' > "${ROOTFS}/etc/resolv.conf"
    fi
  fi
}

if [ -r "${CONF_FILE}" ]; then
  # shellcheck disable=SC1090
  set -a
  . "${CONF_FILE}"
  set +a
fi

if [ ! -x "${ROOTFS}${CHROOT_CTL}" ]; then
  echo "missing chroot identity control entrypoint: ${ROOTFS}${CHROOT_CTL}" >&2
  exit 1
fi

ensure_chroot_mounts_and_resolv

exec /system/bin/chroot "${ROOTFS}" "${CHROOT_CTL}" "$@"
