#!/bin/bash
set -euo pipefail

HELPER="/usr/local/bin/adguardhome-doh-identities.py"

if [[ ! -x "${HELPER}" ]]; then
  echo "missing helper: ${HELPER}" >&2
  exit 1
fi

if command -v python3 >/dev/null 2>&1; then
  exec python3 "${HELPER}" "$@"
fi
if [[ -x /usr/bin/python3 ]]; then
  exec /usr/bin/python3 "${HELPER}" "$@"
fi
if [[ -x /bin/python3 ]]; then
  exec /bin/python3 "${HELPER}" "$@"
fi

echo "python3 is required for adguardhome-doh-identityctl" >&2
exit 1
