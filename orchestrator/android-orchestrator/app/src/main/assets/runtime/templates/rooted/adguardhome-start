is_stack_process_cmdline() {
  local cmd="${1:-}"
  [[ "${cmd}" == *"AdGuardHome"* ]] || [[ "${cmd}" == *"adguardhome"* ]] || [[ "${cmd}" == *"pixel-stack"* ]] || [[ "${cmd}" == *"nginx"* ]]
}

cleanup_stack_listener_port() {
  local port="$1"
  local pid cmdline
  local had_listener=0

  for pid in $(listener_pids_for_port "${port}" 2>/dev/null || true); do
    [[ -n "${pid}" ]] || continue
    had_listener=1
    cmdline="$(pid_cmdline "${pid}" 2>/dev/null || true)"
    if is_stack_process_cmdline "${cmdline}"; then
      echo_log "Stopping stale stack listener owner pid=${pid} on :${port} (${cmdline:-unknown-cmd})"
      kill "${pid}" >/dev/null 2>&1 || true
      sleep 1
      kill -9 "${pid}" >/dev/null 2>&1 || true
    else
      echo_log "Port :${port} already in use by non-stack process pid=${pid} (${cmdline:-unknown-cmd})"
      return 1
    fi
  done

  if [[ "${had_listener}" -eq 1 ]]; then
    sleep 1
  fi
  return 0
}

http_code_local() {
  local url="$1"
  local code
  if ! command -v curl >/dev/null 2>&1; then
    echo "000"
    return 0
  fi
  code="$(curl -ksS -o /dev/null -w '%{http_code}' --max-time 4 "${url}" 2>/dev/null || true)"
  if [[ "${code}" =~ ^[0-9]{3}$ ]]; then
    echo "${code}"
  else
    echo "000"
  fi
}

http_code_reachable_non_route_miss() {
  local code="${1:-}"
  [[ "${code}" =~ ^[0-9]{3}$ ]] || return 1
  [[ "${code}" != "000" && "${code}" != "404" ]]
}

http_code_inconclusive() {
  local code="${1:-}"
  [[ "${code}" == "000" ]]
}

