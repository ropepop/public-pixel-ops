adguard_admin_password() {
  if [[ -r "${PIHOLE_REMOTE_ADMIN_PASSWORD_SECRET_FILE}" ]]; then
    tr -d '\r' < "${PIHOLE_REMOTE_ADMIN_PASSWORD_SECRET_FILE}" | head -n1
    return 0
  fi
  if [[ -r "${ADGUARDHOME_ADMIN_PASSWORD_FILE}" ]]; then
    tr -d '\r' < "${ADGUARDHOME_ADMIN_PASSWORD_FILE}" | head -n1
    return 0
  fi
  return 1
}

adguard_admin_password_hash() {
  local hash_from_file
  if [[ -r "${ADGUARDHOME_ADMIN_PASSWORD_HASH_FILE}" ]]; then
    hash_from_file="$(tr -d '\r' < "${ADGUARDHOME_ADMIN_PASSWORD_HASH_FILE}" | head -n1)"
    if [[ "${hash_from_file}" =~ ^\$2[aby]\$[0-9]{2}\$.{53}$ ]]; then
      printf '%s\n' "${hash_from_file}"
      return 0
    fi
    echo_log "WARN: ignoring invalid bcrypt hash in ${ADGUARDHOME_ADMIN_PASSWORD_HASH_FILE}"
  fi

  local password
  password="$(adguard_admin_password 2>/dev/null || true)"
  [[ -n "${password}" ]] || return 1

  if command -v htpasswd >/dev/null 2>&1; then
    htpasswd -nbBC 10 "" "${password}" 2>/dev/null | tr -d ':\n' | sed 's/^\$2y/\$2a/'
    return 0
  fi

  hash_from_file="$(config_password_hash_from_file "${ADGUARDHOME_CONFIG_FILE}" 2>/dev/null || true)"
  if [[ "${hash_from_file}" =~ ^\$2[aby]\$[0-9]{2}\$.{53}$ ]]; then
    echo_log "WARN: reusing existing admin password hash from ${ADGUARDHOME_CONFIG_FILE}"
    printf '%s\n' "${hash_from_file}"
    return 0
  fi

  hash_from_file="$(config_password_hash_from_file "${ADGUARDHOME_CONFIG_LAST_GOOD_FILE}" 2>/dev/null || true)"
  if [[ "${hash_from_file}" =~ ^\$2[aby]\$[0-9]{2}\$.{53}$ ]]; then
    echo_log "WARN: reusing admin password hash from ${ADGUARDHOME_CONFIG_LAST_GOOD_FILE}"
    printf '%s\n' "${hash_from_file}"
    return 0
  fi

  return 1
}

render_adguardhome_config() {
  local hash_line hash_value tmpfile=""
  local upstream_block tls_block dot_port web_bind doh_mode
  local managed_identity_clients_block strict_sni_check_line
  local preserved_dynamic_blocks schema_version
  mkdir -p "${ADGUARDHOME_CONF_DIR}" "${ADGUARDHOME_WORK_DIR}" "${ADGUARDHOME_WORK_DIR}/data" "${ADGUARDHOME_WORK_DIR}/filters"

  hash_value="$(adguard_admin_password_hash 2>/dev/null || true)"
  hash_line=""
  if [[ -n "${hash_value}" ]]; then
    hash_line="    password: \"${hash_value}\""
  elif remote_admin_enabled; then
    echo_log "Managed remote admin is enabled but no password hash is available; refusing to render authless config"
    return 1
  fi

  upstream_block=""
  if [[ -n "${PIHOLE_DOH_UPSTREAM_1}" ]]; then
    upstream_block+="    - ${PIHOLE_DOH_UPSTREAM_1}"
    upstream_block+=$'\n'
  fi
  if [[ -n "${PIHOLE_DOH_UPSTREAM_2}" ]]; then
    upstream_block+="    - ${PIHOLE_DOH_UPSTREAM_2}"
    upstream_block+=$'\n'
  fi
  if [[ -z "${upstream_block}" ]]; then
    upstream_block="    - https://1.1.1.1/dns-query\n    - https://1.0.0.1/dns-query\n"
  fi

  managed_identity_clients_block=""
  if remote_dot_identity_enabled; then
    if ! managed_identity_clients_block="$(render_adguard_managed_identity_clients)"; then
      echo_log "Failed to render managed DoT identity clients via ${PIHOLE_REMOTE_DOH_IDENTITYCTL}"
      return 1
    fi
  fi

  doh_mode="$(doh_endpoint_mode 2>/dev/null || printf 'native')"
  web_bind="0.0.0.0:${PIHOLE_WEB_PORT}"
  if remote_frontend_via_nginx; then
    web_bind="127.0.0.1:${PIHOLE_WEB_PORT}"
  fi

  dot_port=0
  if remote_dot_enabled; then
    dot_port="$(effective_adguard_dot_port)"
  fi

  strict_sni_check_line=""
  if remote_dot_identity_enabled && remote_frontend_via_nginx && remote_dot_enabled; then
    strict_sni_check_line="  strict_sni_check: true"$'\n'
  fi

  preserved_dynamic_blocks="$(render_preserved_adguardhome_dynamic_blocks 2>/dev/null || true)"
  if [[ -n "${preserved_dynamic_blocks}" ]]; then
    preserved_dynamic_blocks+=$'\n'
  fi
  schema_version="$(existing_schema_version 2>/dev/null || printf '28')"

  if remote_frontend_via_nginx; then
    if remote_dot_enabled; then
      tls_block="$(cat <<EOF_TLS
tls:
  enabled: true
  server_name: ${PIHOLE_REMOTE_DOT_HOSTNAME}
${strict_sni_check_line}  force_https: false
  port_https: 0
  port_dns_over_tls: ${dot_port}
  port_dns_over_quic: 0
  allow_unencrypted_doh: true
  certificate_path: "${PIHOLE_REMOTE_TLS_CERT_FILE}"
  private_key_path: "${PIHOLE_REMOTE_TLS_KEY_FILE}"
EOF_TLS
)"
    else
      tls_block="$(cat <<EOF_TLS
tls:
  enabled: false
  force_https: false
  port_https: 0
  port_dns_over_tls: 0
  port_dns_over_quic: 0
  allow_unencrypted_doh: true
EOF_TLS
)"
    fi
  elif remote_stack_enabled; then
    tls_block="$(cat <<EOF_TLS
tls:
  enabled: true
  server_name: ${PIHOLE_REMOTE_HOSTNAME}
  force_https: true
  port_https: ${PIHOLE_REMOTE_HTTPS_PORT}
  port_dns_over_tls: ${dot_port}
  port_dns_over_quic: 0
  allow_unencrypted_doh: false
  certificate_path: "${PIHOLE_REMOTE_TLS_CERT_FILE}"
  private_key_path: "${PIHOLE_REMOTE_TLS_KEY_FILE}"
EOF_TLS
)"
  else
    tls_block="$(cat <<EOF_TLS
tls:
  enabled: false
  force_https: false
  port_https: 0
  port_dns_over_tls: 0
  port_dns_over_quic: 0
  allow_unencrypted_doh: false
EOF_TLS
)"
  fi

  tmpfile="$(mktemp "${ADGUARDHOME_CONF_DIR}/AdGuardHome.yaml.XXXXXX")"
  cat > "${tmpfile}" <<EOF_CFG
http:
  address: ${web_bind}
  trusted_proxies:
    - 127.0.0.0/8
    - ::1/128
users:
  - name: "${ADGUARDHOME_ADMIN_USERNAME}"
${hash_line}
dns:
  bind_hosts:
    - 0.0.0.0
  port: ${PIHOLE_ACTIVE_DNS_PORT}
  upstream_dns:
${upstream_block}  bootstrap_dns:
    - 1.1.1.1
    - 1.0.0.1
  all_servers: false
  ratelimit: 0
${tls_block}
querylog:
  anonymize_client_ip: false
  enabled: true
clients:
  persistent:
    - name: "Loopback internal"
      ids:
        - 127.0.0.1
        - ::1
      ignore_querylog: true
      ignore_statistics: true
${managed_identity_clients_block}
${preserved_dynamic_blocks}log:
  file: "${ADGUARDHOME_LOG_DIR}/adguardhome.log"
  max_size: 100
schema_version: ${schema_version}
EOF_CFG
  chmod 600 "${tmpfile}" || true
  if ! validate_rendered_config "${tmpfile}"; then
    rm -f "${tmpfile}" >/dev/null 2>&1 || true
    return 1
  fi

  mv -f "${tmpfile}" "${ADGUARDHOME_CONFIG_FILE}"
}

cleanup_legacy_remote_stack() {
  # Cleanup stale pre-cutover sidecars and previously managed nginx instances.
  kill_pidfile "${PIHOLE_REMOTE_NGINX_PID_FILE}"
  kill_pidfile "${PIHOLE_REMOTE_DOH_IDENTITY_WEB_PID_FILE}"
  pkill -f 'adguardhome-doh-gateway' >/dev/null 2>&1 || true
  pkill -f 'adguardhome-doh-identity-web.py' >/dev/null 2>&1 || true
  pkill -f 'pixel-stack-adguardhome-remote-nginx.conf' >/dev/null 2>&1 || true
  pkill -f 'nginx.*remote-nginx' >/dev/null 2>&1 || true
  cleanup_stack_listener_port "${PIHOLE_REMOTE_HTTPS_PORT}" || return 1
}

render_remote_nginx_config() {
  local doh_mode bare_doh_block token_doh_block doh_client_ip_map_block
  local nginx_load_modules_block stream_dot_gate_block dot_sni_map_block dot_backend
  local router_lan_ip router_public_ip
  local tmpfile

  if ! remote_frontend_via_nginx; then
    return 0
  fi
  if [[ ! -r "${PIHOLE_REMOTE_NGINX_TEMPLATE_FILE}" ]]; then
    echo_log "missing nginx template: ${PIHOLE_REMOTE_NGINX_TEMPLATE_FILE}"
    return 1
  fi

  doh_mode="$(doh_endpoint_mode 2>/dev/null || printf 'native')"
  bare_doh_block="$(cat <<'EOF_BARE_404'
    location = /dns-query {
      access_log /var/log/adguardhome/remote-nginx-doh-access.log pixel_doh;
      return 404;
    }
EOF_BARE_404
)"
  token_doh_block=""
  nginx_load_modules_block=""
  stream_dot_gate_block=""
  doh_client_ip_map_block="$(cat <<'EOF_DOH_MAP'
  map $remote_addr $doh_client_ip {
    default $remote_addr;
  }
EOF_DOH_MAP
)"

  if router_public_ip_attribution_enabled; then
    router_lan_ip="$(printf '%s' "${ADGUARDHOME_REMOTE_ROUTER_LAN_IP}" | tr -d '[:space:]')"
    if ! is_valid_ipv4 "${router_lan_ip}"; then
      echo_log "WARN: router public IP attribution enabled but ADGUARDHOME_REMOTE_ROUTER_LAN_IP is invalid (${router_lan_ip:-empty}); using remote_addr"
    else
      router_public_ip="$(ddns_last_ipv4 2>/dev/null || true)"
      if ! is_valid_ipv4 "${router_public_ip}"; then
        echo_log "WARN: router public IP attribution enabled but DDNS public IPv4 unavailable at ${PIHOLE_DDNS_LAST_IPV4_FILE} (fallback ${PIHOLE_DDNS_LAST_IPV4_FALLBACK_FILE}); using remote_addr"
      else
        doh_client_ip_map_block="$(cat <<EOF_DOH_MAP
  map \$remote_addr \$doh_client_ip {
    default \$remote_addr;
    ${router_lan_ip} ${router_public_ip};
  }
EOF_DOH_MAP
)"
      fi
    fi
  fi

  if remote_doh_enabled; then
    case "${doh_mode}" in
      dual)
        bare_doh_block="$(cat <<EOF_BARE_PROXY
    location = /dns-query {
      access_log /var/log/adguardhome/remote-nginx-doh-access.log pixel_doh;
      proxy_pass http://127.0.0.1:${PIHOLE_WEB_PORT}/dns-query;
      proxy_set_header Host \$host;
      proxy_set_header X-Forwarded-For \$doh_client_ip;
      proxy_set_header X-Real-IP \$doh_client_ip;
      proxy_set_header X-Forwarded-Proto https;
    }
EOF_BARE_PROXY
)"
        ;;
      tokenized|native)
        ;;
    esac

    if doh_mode_requires_token; then
      token_doh_block="$(render_doh_identity_nginx_block || true)"
      if [[ -z "${token_doh_block}" ]]; then
        echo_log "Failed to render tokenized DoH nginx block from identity store"
        return 1
      fi
    fi
  fi

  if remote_dot_frontend_via_nginx; then
    dot_backend="127.0.0.1:${ADGUARDHOME_REMOTE_DOT_INTERNAL_PORT}"
    dot_sni_map_block="$(render_dot_identity_nginx_sni_map "${dot_backend}" || true)"
    if [[ -z "${dot_sni_map_block}" ]]; then
      echo_log "Failed to render DoT SNI allow map from identity store"
      return 1
    fi

    nginx_load_modules_block="load_module /usr/lib/nginx/modules/ngx_stream_module.so;"
    stream_dot_gate_block="$(cat <<EOF_STREAM_GATE
stream {
  log_format pixel_dot '\$time_iso8601\t\$ssl_preread_server_name\t\$status\t\$session_time\t\$remote_addr\t\$msec';
  access_log /var/log/adguardhome/remote-nginx-dot-access.log pixel_dot;

  map \$ssl_preread_server_name \$dot_backend {
${dot_sni_map_block}
  }

  server {
    listen ${PIHOLE_REMOTE_DOT_PORT};
    listen [::]:${PIHOLE_REMOTE_DOT_PORT};
    proxy_connect_timeout 1s;
    proxy_timeout ${PIHOLE_REMOTE_DOT_PROXY_TIMEOUT_SECONDS}s;
    ssl_preread on;
    proxy_pass \$dot_backend;
  }
}
EOF_STREAM_GATE
)"
  fi

  tmpfile="$(mktemp)"
  awk \
    -v https_port="${PIHOLE_REMOTE_HTTPS_PORT}" \
    -v hostname="${PIHOLE_REMOTE_HOSTNAME}" \
    -v web_port="${PIHOLE_WEB_PORT}" \
    -v identity_web_port="${PIHOLE_REMOTE_DOH_IDENTITY_WEB_PORT}" \
    -v cert_file="${PIHOLE_REMOTE_TLS_CERT_FILE}" \
    -v key_file="${PIHOLE_REMOTE_TLS_KEY_FILE}" \
    -v nginx_load_modules_block="${nginx_load_modules_block}" \
    -v stream_dot_gate_block="${stream_dot_gate_block}" \
    -v doh_client_map_block="${doh_client_ip_map_block}" \
    -v bare_block="${bare_doh_block}" \
    -v token_block="${token_doh_block}" \
    '
      $0 == "__NGINX_LOAD_MODULES_BLOCK__" { print nginx_load_modules_block; next }
      $0 == "__STREAM_DOT_GATE_BLOCK__" { print stream_dot_gate_block; next }
      $0 == "__DOH_CLIENT_IP_MAP_BLOCK__" { print doh_client_map_block; next }
      $0 == "__DOH_BARE_BLOCK__" { print bare_block; next }
      $0 == "__DOH_TOKEN_BLOCK__" { print token_block; next }
      {
        gsub("__HTTPS_PORT__", https_port)
        gsub("__HOSTNAME__", hostname)
        gsub("__WEB_PORT__", web_port)
        gsub("__IDENTITY_WEB_PORT__", identity_web_port)
        gsub("__TLS_CERT_FILE__", cert_file)
        gsub("__TLS_KEY_FILE__", key_file)
        print
      }
    ' "${PIHOLE_REMOTE_NGINX_TEMPLATE_FILE}" > "${tmpfile}"
  if ! validate_remote_nginx_config "${tmpfile}"; then
    rm -f "${tmpfile}" >/dev/null 2>&1 || true
    return 1
  fi
  install -m 0600 "${tmpfile}" "${PIHOLE_REMOTE_NGINX_CONF_FILE}"
  rm -f "${tmpfile}" >/dev/null 2>&1 || true
}

validate_remote_nginx_config() {
  local file="${1:-}"
  local nginx_bin

  if ! remote_frontend_via_nginx; then
    return 0
  fi
  [[ -n "${file}" ]] || {
    echo_log "missing nginx config path for validation"
    return 1
  }
  [[ -s "${file}" ]] || {
    echo_log "rendered nginx config is empty: ${file}"
    return 1
  }

  nginx_bin="$(find_nginx_bin 2>/dev/null || true)"
  if [[ -z "${nginx_bin}" ]]; then
    echo_log "nginx binary is required for mode=$(doh_endpoint_mode 2>/dev/null || printf unknown) but not found"
    return 1
  fi

  "${nginx_bin}" -t -c "${file}" -p / >/dev/null 2>&1 || {
    echo_log "nginx config validation failed for ${file}"
    return 1
  }
}

stop_remote_nginx() {
  kill_pidfile "${PIHOLE_REMOTE_NGINX_PID_FILE}"
  pkill -f 'pixel-stack-adguardhome-remote-nginx.conf' >/dev/null 2>&1 || true
  pkill -f 'nginx.*remote-nginx' >/dev/null 2>&1 || true
  cleanup_stack_listener_port "${PIHOLE_REMOTE_HTTPS_PORT}" || return 1
}

stop_identity_web_sidecar() {
  kill_pidfile "${PIHOLE_REMOTE_DOH_IDENTITY_WEB_PID_FILE}"
  pkill -f 'adguardhome-doh-identity-web.py' >/dev/null 2>&1 || true
}

start_identity_web_sidecar() {
  local pid python_bin

  if ! remote_frontend_via_nginx; then
    stop_identity_web_sidecar || true
    return 0
  fi

  if [[ ! -x "${PIHOLE_REMOTE_DOH_IDENTITY_WEB}" ]]; then
    echo_log "DoH identity web helper missing: ${PIHOLE_REMOTE_DOH_IDENTITY_WEB}"
    stop_identity_web_sidecar || true
    return 1
  fi

  python_bin="$(command -v python3 2>/dev/null || true)"
  if [[ -z "${python_bin}" ]]; then
    if [[ -x /usr/bin/python3 ]]; then
      python_bin="/usr/bin/python3"
    elif [[ -x /bin/python3 ]]; then
      python_bin="/bin/python3"
    else
      echo_log "python3 missing; cannot start DoH identity web sidecar"
      stop_identity_web_sidecar || true
      return 1
    fi
  fi

  pid="$(pid_from_file "${PIHOLE_REMOTE_DOH_IDENTITY_WEB_PID_FILE}" 2>/dev/null || true)"
  if pid_is_running "${pid}" && tcp_listener_local "${PIHOLE_REMOTE_DOH_IDENTITY_WEB_PORT}"; then
    return 0
  fi

  stop_identity_web_sidecar || true
  ADGUARDHOME_DOH_IDENTITY_WEB_IPINFO_LITE_TOKEN_FILE="${PIHOLE_REMOTE_IPINFO_LITE_TOKEN_SECRET_FILE}" \
  ADGUARDHOME_DOH_IDENTITY_WEB_IPINFO_CACHE_FILE="${PIHOLE_REMOTE_DOH_IDENTITY_WEB_IPINFO_CACHE_FILE}" \
  nohup "${python_bin}" "${PIHOLE_REMOTE_DOH_IDENTITY_WEB}" \
    --host "${PIHOLE_REMOTE_DOH_IDENTITY_WEB_HOST}" \
    --port "${PIHOLE_REMOTE_DOH_IDENTITY_WEB_PORT}" \
    --adguard-web-port "${PIHOLE_WEB_PORT}" \
    --identityctl "${PIHOLE_REMOTE_DOH_IDENTITYCTL}" >> "${PIHOLE_REMOTE_DOH_IDENTITY_WEB_LOG_FILE}" 2>&1 &
  echo $! > "${PIHOLE_REMOTE_DOH_IDENTITY_WEB_PID_FILE}"
  sleep 1

  pid="$(pid_from_file "${PIHOLE_REMOTE_DOH_IDENTITY_WEB_PID_FILE}" 2>/dev/null || true)"
  if ! pid_is_running "${pid}"; then
    echo_log "DoH identity web sidecar exited early; see ${PIHOLE_REMOTE_DOH_IDENTITY_WEB_LOG_FILE}"
    return 1
  fi

  for _ in $(seq 1 20); do
    if tcp_listener_local "${PIHOLE_REMOTE_DOH_IDENTITY_WEB_PORT}"; then
      return 0
    fi
    sleep 0.25
  done

  echo_log "DoH identity web sidecar failed to bind :${PIHOLE_REMOTE_DOH_IDENTITY_WEB_PORT}"
  return 1
}

start_remote_nginx() {
  local nginx_bin pid

  if ! remote_frontend_via_nginx; then
    stop_remote_nginx || true
    return 0
  fi

  nginx_bin="$(find_nginx_bin 2>/dev/null || true)"
  if [[ -z "${nginx_bin}" ]]; then
    echo_log "nginx binary is required for mode=$(doh_endpoint_mode 2>/dev/null || printf unknown) but not found"
    return 1
  fi

  render_remote_nginx_config || return 1
  stop_remote_nginx || true
  nohup "${nginx_bin}" -c "${PIHOLE_REMOTE_NGINX_CONF_FILE}" -p / >> "${ADGUARDHOME_RUNTIME_LOG_FILE}" 2>&1 &
  echo $! > "${PIHOLE_REMOTE_NGINX_PID_FILE}"
  sleep 1

  pid="$(pid_from_file "${PIHOLE_REMOTE_NGINX_PID_FILE}" 2>/dev/null || true)"
  if ! pid_is_running "${pid}"; then
    echo_log "nginx frontend failed to stay up"
    return 1
  fi

  for _ in $(seq 1 20); do
    if tcp_listener_local "${PIHOLE_REMOTE_HTTPS_PORT}"; then
      if ! remote_dot_frontend_via_nginx || tcp_listener_local "${PIHOLE_REMOTE_DOT_PORT}"; then
        return 0
      fi
    fi
    sleep 0.5
  done
  echo_log "nginx frontend failed to open required public listeners"
  return 1
}

configure_adguardhome_dns_api() {
  if ! command -v curl >/dev/null 2>&1; then
    return 0
  fi

  local password cookie_file login_code dns_code api_base_url
  api_base_url="http://127.0.0.1:${PIHOLE_WEB_PORT}"

  password="$(adguard_admin_password 2>/dev/null || true)"
  [[ -n "${password}" ]] || return 0

  cookie_file="$(mktemp)"
  login_code="$({
    curl -sS -o /dev/null -w '%{http_code}' -c "${cookie_file}" \
      -H 'Content-Type: application/json' \
      -X POST \
      -d "{\"name\":\"${ADGUARDHOME_ADMIN_USERNAME}\",\"password\":\"${password}\"}" \
      "${api_base_url}/control/login"
  } 2>/dev/null || true)"

  if [[ "${login_code}" != "200" ]]; then
    rm -f "${cookie_file}"
    echo_log "WARN: AdGuard API login failed while applying DNS upstreams (code=${login_code})"
    return 0
  fi

  dns_code="$({
    curl -sS -o /dev/null -w '%{http_code}' -b "${cookie_file}" \
      -H 'Content-Type: application/json' \
      -X POST \
      -d "{\"upstream_dns\":[\"${PIHOLE_DOH_UPSTREAM_1}\",\"${PIHOLE_DOH_UPSTREAM_2}\"],\"bootstrap_dns\":[\"1.1.1.1\",\"1.0.0.1\"]}" \
      "${api_base_url}/control/dns_config"
  } 2>/dev/null || true)"

  rm -f "${cookie_file}"
  if [[ "${dns_code}" != "200" ]]; then
    echo_log "WARN: failed to apply DNS upstreams via AdGuard API (code=${dns_code})"
  fi
}

prepare_runtime() {
  validate_doh_mode_and_token || return 1
  sync_runtime_secrets
  write_remote_runtime_env_file
  validate_numeric_ports || {
    echo_log "Invalid numeric remote/listener settings"
    return 1
  }
  if remote_stack_enabled; then
    validate_remote_hostname || {
      echo_log "Invalid PIHOLE_REMOTE_HOSTNAME=${PIHOLE_REMOTE_HOSTNAME}"
      return 1
    }
    if remote_dot_enabled; then
      validate_remote_dot_hostname || {
        echo_log "Invalid PIHOLE_REMOTE_DOT_HOSTNAME=${PIHOLE_REMOTE_DOT_HOSTNAME}"
        return 1
      }
    fi
    ensure_remote_tls || return 1
  fi

  if ! render_adguardhome_config; then
    restore_last_good_adguardhome_config || return 1
    return 1
  fi
  if remote_frontend_via_nginx; then
    render_remote_nginx_config || return 1
  fi
  ensure_proc_self_exe_available || return 1
}

stop_adguardhome_core() {
  kill_pidfile "${ADGUARDHOME_PID_FILE}"
  pkill -f 'AdGuardHome' >/dev/null 2>&1 || true
}

launch_adguardhome_core() {
  local adguard_bin doh_mode
  adguard_bin="$(find_adguardhome_bin 2>/dev/null || true)"
  if [[ -z "${adguard_bin}" ]]; then
    echo_log "AdGuardHome binary not found; attempting bootstrap install from ${ADGUARDHOME_RELEASE_URL}"
    if install_adguardhome_binary; then
      adguard_bin="$(find_adguardhome_bin 2>/dev/null || true)"
    fi
    if [[ -z "${adguard_bin}" ]]; then
      echo_log "AdGuardHome binary not found after bootstrap install attempt"
      return 1
    fi
  fi

  doh_mode="$(doh_endpoint_mode 2>/dev/null || printf 'native')"
  if [[ -f "${ADGUARDHOME_PID_FILE}" ]]; then
    local old_pid
    old_pid="$(cat "${ADGUARDHOME_PID_FILE}" 2>/dev/null || true)"
    if pid_is_adguardhome_process "${old_pid}"; then
      if tcp_listener_local "${PIHOLE_WEB_PORT}" && ! adguardhome_entered_setup_mode; then
        echo_log "AdGuardHome already running (pid=${old_pid})"
        return 0
      fi
      echo_log "AdGuardHome is running without the managed web listener; performing a clean restart (pid=${old_pid})"
      stop_adguardhome_core || true
    fi
    if [[ -n "${old_pid}" ]]; then
      echo_log "Removing stale AdGuardHome pid file (pid=${old_pid})"
    else
      echo_log "Removing stale AdGuardHome pid file (empty pid)"
    fi
    rm -f "${ADGUARDHOME_PID_FILE}" >/dev/null 2>&1 || true
  fi

  echo_log "Starting AdGuardHome (dns=:${PIHOLE_ACTIVE_DNS_PORT}, web=:${PIHOLE_WEB_PORT}, doh_mode=${doh_mode})"
  local runtime_start_line startup_attempt_log pid
  runtime_start_line="$(wc -l < "${ADGUARDHOME_RUNTIME_LOG_FILE}" 2>/dev/null || echo 0)"
  startup_attempt_log="${ADGUARDHOME_LOG_DIR}/adguardhome-start-attempt-$(date +%Y%m%dT%H%M%S)-$$.log"
  {
    echo "start_ts=$(ts)"
    echo "dns_port=${PIHOLE_ACTIVE_DNS_PORT} web_port=${PIHOLE_WEB_PORT} doh_mode=${doh_mode}"
    echo "adguard_bin=${adguard_bin}"
    echo "runtime_log_start_line=${runtime_start_line}"
  } > "${startup_attempt_log}"
  if ! "${adguard_bin}" --version >> "${startup_attempt_log}" 2>&1; then
    echo_log "AdGuardHome binary preflight exec failed; see ${startup_attempt_log}"
    emit_runtime_attempt_excerpt "${runtime_start_line}" "${startup_attempt_log}" 80
    return 1
  fi
  rm -f "${ADGUARDHOME_PID_FILE}" >/dev/null 2>&1 || true
  nohup "${adguard_bin}" --no-check-update --pidfile "${ADGUARDHOME_PID_FILE}" \
    -c "${ADGUARDHOME_CONFIG_FILE}" -w "${ADGUARDHOME_WORK_DIR}" \
    >> "${ADGUARDHOME_RUNTIME_LOG_FILE}" 2>&1 &

  pid="$(wait_for_pidfile_process "${ADGUARDHOME_PID_FILE}" 15000 2>/dev/null || true)"
  if ! pid_is_running "${pid}"; then
    echo_log "AdGuardHome exited early (pidfile wait timeout or process not alive); attempt_log=${startup_attempt_log}"
    emit_runtime_attempt_excerpt "${runtime_start_line}" "${startup_attempt_log}" 80
    return 1
  fi

  local _ adguard_dot_port
  adguard_dot_port="$(effective_adguard_dot_port)"
  for _ in $(seq 1 20); do
    if adguardhome_entered_setup_mode; then
      echo_log "AdGuardHome entered setup mode on :${ADGUARDHOME_SETUP_WEB_PORT}; restoring last-known-good config"
      kill_pidfile "${ADGUARDHOME_PID_FILE}"
      pkill -f 'AdGuardHome' >/dev/null 2>&1 || true
      restore_last_good_adguardhome_config || return 1
      runtime_status_summary
      return 1
    fi
    tcp_listener_local "${PIHOLE_ACTIVE_DNS_PORT}" || { sleep 0.5; continue; }
    tcp_listener_local "${PIHOLE_WEB_PORT}" || { sleep 0.5; continue; }
    if remote_dot_enabled; then
      tcp_listener_local "${adguard_dot_port}" || { sleep 0.5; continue; }
    fi
    if remote_stack_enabled && ! remote_frontend_via_nginx; then
      tcp_listener_local "${PIHOLE_REMOTE_HTTPS_PORT}" || { sleep 0.5; continue; }
    fi
    configure_adguardhome_dns_api || true
    break
  done

  if ! tcp_listener_local "${PIHOLE_ACTIVE_DNS_PORT}" || ! tcp_listener_local "${PIHOLE_WEB_PORT}"; then
    echo_log "AdGuardHome listeners failed to appear on :${PIHOLE_ACTIVE_DNS_PORT}/:${PIHOLE_WEB_PORT}"
    if adguardhome_entered_setup_mode; then
      echo_log "AdGuardHome setup listener is active on :${ADGUARDHOME_SETUP_WEB_PORT}; restoring last-known-good config"
      kill_pidfile "${ADGUARDHOME_PID_FILE}"
      pkill -f 'AdGuardHome' >/dev/null 2>&1 || true
      restore_last_good_adguardhome_config || return 1
    fi
    runtime_status_summary
    return 1
  fi
  backup_last_good_adguardhome_config || echo_log "WARN: failed to refresh last-known-good AdGuardHome config backup"
  if remote_dot_enabled && ! tcp_listener_local "${adguard_dot_port}"; then
    echo_log "AdGuardHome DoT listener failed to appear on :${adguard_dot_port}"
    runtime_status_summary
    return 1
  fi

  return 0
}

launch_remote_frontend() {
  if ! remote_stack_enabled; then
    stop_identity_web_sidecar || true
    stop_remote_nginx || true
    return 0
  fi

  validate_remote_hostname || {
    echo_log "Invalid PIHOLE_REMOTE_HOSTNAME=${PIHOLE_REMOTE_HOSTNAME}"
    return 1
  }
  if remote_dot_enabled; then
    validate_remote_dot_hostname || {
      echo_log "Invalid PIHOLE_REMOTE_DOT_HOSTNAME=${PIHOLE_REMOTE_DOT_HOSTNAME}"
      return 1
    }
  fi
  validate_numeric_ports || {
    echo_log "Invalid numeric remote/listener settings"
    return 1
  }
  validate_doh_mode_and_token || return 1
  sync_runtime_secrets
  write_remote_runtime_env_file
  ensure_remote_tls || return 1

  if remote_frontend_via_nginx; then
    local adguard_pid
    adguard_pid="$(pid_from_file "${ADGUARDHOME_PID_FILE}" 2>/dev/null || true)"
    if ! pid_is_running "${adguard_pid}" || ! tcp_listener_local "${PIHOLE_WEB_PORT}"; then
      echo_log "AdGuardHome web listener unavailable; cannot start remote frontend"
      return 1
    fi
    start_identity_web_sidecar || return 1
    start_remote_nginx || return 1
  fi

  if ! tcp_listener_local "${PIHOLE_REMOTE_HTTPS_PORT}"; then
    echo_log "Remote HTTPS listener failed to appear on :${PIHOLE_REMOTE_HTTPS_PORT}"
    runtime_status_summary
    return 1
  fi

  remote_stack_healthcheck || return 1
  return 0
}

start_adguardhome() {
  prepare_runtime || return 1
  launch_adguardhome_core || return 1
  launch_remote_frontend || return 1
  return 0
}

stop_adguardhome() {
  stop_remote_watchdog || true
  stop_identity_web_sidecar || true
  stop_remote_nginx || true
  stop_adguardhome_core || true
}

remote_admin_upstream_healthy() {
  local code
  code="$(http_code_local "https://127.0.0.1:${PIHOLE_REMOTE_HTTPS_PORT}/")"
  case "${code}" in
    200|301|302|303|307|308|401) return 0 ;;
    000) return 0 ;;
    *) return 1 ;;
  esac
}

identity_frontend_healthy() {
  local pid inject_code

  if ! remote_frontend_via_nginx; then
    return 0
  fi

  pid="$(pid_from_file "${PIHOLE_REMOTE_DOH_IDENTITY_WEB_PID_FILE}" 2>/dev/null || true)"
  pid_is_running "${pid}" || return 1
  tcp_listener_local "${PIHOLE_REMOTE_DOH_IDENTITY_WEB_PORT}" || return 1

  if command -v curl >/dev/null 2>&1; then
    inject_code="$(http_code_local "https://127.0.0.1:${PIHOLE_REMOTE_HTTPS_PORT}/pixel-stack/identity/inject.js")"
    if http_code_inconclusive "${inject_code}"; then
      return 0
    fi
    [[ "${inject_code}" == "200" ]] || return 1
  fi

  return 0
}

remote_doh_contract_healthy() {
  local mode tokenized_url bare_url tokenized_code bare_code primary_token
  local tokenized_reachable bare_reachable

  if ! remote_doh_enabled; then
    return 0
  fi
  if ! command -v curl >/dev/null 2>&1; then
    return 0
  fi

  mode="$(doh_endpoint_mode 2>/dev/null || printf 'native')"
  bare_url="https://127.0.0.1:${PIHOLE_REMOTE_HTTPS_PORT}/dns-query"
  bare_code="$(http_code_local "${bare_url}")"
  bare_reachable=0
  if http_code_reachable_non_route_miss "${bare_code}"; then
    bare_reachable=1
  fi

  tokenized_code="000"
  tokenized_reachable=0
  if doh_mode_requires_token; then
    primary_token="$(primary_doh_token 2>/dev/null || true)"
    if ! validate_doh_token "${primary_token}"; then
      return 1
    fi
    tokenized_url="https://127.0.0.1:${PIHOLE_REMOTE_HTTPS_PORT}/${primary_token}/dns-query"
    tokenized_code="$(http_code_local "${tokenized_url}")"
    if http_code_reachable_non_route_miss "${tokenized_code}"; then
      tokenized_reachable=1
    fi
  fi

  case "${mode}" in
    tokenized)
      if http_code_inconclusive "${tokenized_code}" || http_code_inconclusive "${bare_code}"; then
        return 0
      fi
      ;;
    dual)
      if http_code_inconclusive "${tokenized_code}" || http_code_inconclusive "${bare_code}"; then
        return 0
      fi
      ;;
    native)
      if http_code_inconclusive "${bare_code}"; then
        return 0
      fi
      ;;
  esac

  case "${mode}" in
    tokenized) [[ "${tokenized_reachable}" -eq 1 && "${bare_code}" == "404" ]] ;;
    dual) [[ "${tokenized_reachable}" -eq 1 && "${bare_reachable}" -eq 1 ]] ;;
    native) [[ "${bare_reachable}" -eq 1 ]] ;;
    *) return 1 ;;
  esac
}

restart_adguardhome_runtime() {
  stop_adguardhome
  start_adguardhome
}

stop_remote_watchdog() {
  kill_pidfile "${PIHOLE_REMOTE_WATCHDOG_PID_FILE}"
  pkill -f 'adguardhome-remote-watchdog' >/dev/null 2>&1 || true
}

start_remote_watchdog() {
  if ! is_true "${PIHOLE_REMOTE_WATCHDOG_ENABLED}"; then
    stop_remote_watchdog || true
    return 0
  fi
  if [[ ! -x "${PIHOLE_REMOTE_WATCHDOG_HELPER}" ]]; then
    echo_log "watchdog helper missing: ${PIHOLE_REMOTE_WATCHDOG_HELPER}"
    return 1
  fi

  stop_remote_watchdog || true
  nohup "${PIHOLE_REMOTE_WATCHDOG_HELPER}" >> "${PIHOLE_REMOTE_WATCHDOG_LOG_FILE}" 2>&1 &
  echo $! > "${PIHOLE_REMOTE_WATCHDOG_PID_FILE}"
  sleep 1

  local pid
  pid="$(pid_from_file "${PIHOLE_REMOTE_WATCHDOG_PID_FILE}" 2>/dev/null || true)"
  pid_is_running "${pid}"
}

ensure_remote_tls() {
  if ! remote_doh_enabled && ! remote_dot_enabled && ! remote_admin_enabled; then
    return 0
  fi

  if [[ -r "${PIHOLE_REMOTE_TLS_CERT_FILE}" && -r "${PIHOLE_REMOTE_TLS_KEY_FILE}" ]]; then
    return 0
  fi

  if [[ ! -x "${PIHOLE_REMOTE_ACME_HELPER}" ]]; then
    echo_log "missing ACME helper and no TLS certs available"
    return 1
  fi

  set +e
  "${PIHOLE_REMOTE_ACME_HELPER}" ensure >> "${PIHOLE_REMOTE_ACME_LOG_FILE}" 2>&1
  local rc=$?
  set -e
  case "${rc}" in
    0|10|11)
      ;;
    *)
      echo_log "remote ACME helper failed with rc=${rc}"
      return 1
      ;;
  esac

  [[ -r "${PIHOLE_REMOTE_TLS_CERT_FILE}" && -r "${PIHOLE_REMOTE_TLS_KEY_FILE}" ]]
}

remote_stack_healthcheck() {
  if ! remote_stack_enabled; then
    return 0
  fi
  validate_doh_mode_and_token || return 1

  if ! tcp_listener_local "${PIHOLE_REMOTE_HTTPS_PORT}"; then
    return 1
  fi

  if remote_dot_enabled; then
    tcp_listener_local "${PIHOLE_REMOTE_DOT_PORT}" || return 1
  fi

  if remote_frontend_via_nginx; then
    identity_frontend_healthy || return 1
  fi

  if remote_admin_enabled; then
    remote_admin_upstream_healthy || return 1
  fi
  if remote_doh_enabled; then
    remote_doh_contract_healthy || return 1
  fi

  return 0
}

remote_stack_healthcheck_debug() {
  local https_listener dot_listener web_listener identity_pid identity_alive identity_listener
  local inject_code admin_code mode bare_code tokenized_code primary_token overall

  if ! remote_stack_enabled; then
    printf 'remote_stack_enabled=no\n'
    return 0
  fi

  printf 'remote_stack_enabled=yes\n'
  if validate_doh_mode_and_token; then
    printf 'doh_token_validation=ok\n'
  else
    printf 'doh_token_validation=fail\n'
  fi

  if tcp_listener_local "${PIHOLE_REMOTE_HTTPS_PORT}"; then
    https_listener=up
  else
    https_listener=down
  fi
  printf 'https_listener=%s\n' "${https_listener}"

  if tcp_listener_local "${PIHOLE_WEB_PORT}"; then
    web_listener=up
  else
    web_listener=down
  fi
  printf 'web_listener=%s\n' "${web_listener}"

  if remote_dot_enabled; then
    if tcp_listener_local "${PIHOLE_REMOTE_DOT_PORT}"; then
      dot_listener=up
    else
      dot_listener=down
    fi
    printf 'dot_listener=%s\n' "${dot_listener}"
  else
    printf 'dot_listener=disabled\n'
  fi

  if remote_frontend_via_nginx; then
    identity_pid="$(pid_from_file "${PIHOLE_REMOTE_DOH_IDENTITY_WEB_PID_FILE}" 2>/dev/null || true)"
    if pid_is_running "${identity_pid}"; then
      identity_alive=yes
    else
      identity_alive=no
    fi
    if tcp_listener_local "${PIHOLE_REMOTE_DOH_IDENTITY_WEB_PORT}"; then
      identity_listener=up
    else
      identity_listener=down
    fi
    printf 'identity_pid=%s\n' "${identity_pid:-none}"
    printf 'identity_alive=%s\n' "${identity_alive}"
    printf 'identity_listener=%s\n' "${identity_listener}"
    if command -v curl >/dev/null 2>&1; then
      inject_code="$(http_code_local "https://127.0.0.1:${PIHOLE_REMOTE_HTTPS_PORT}/pixel-stack/identity/inject.js")"
    else
      inject_code="curl_missing"
    fi
    printf 'identity_inject_code=%s\n' "${inject_code}"
  else
    printf 'identity_pid=disabled\n'
    printf 'identity_alive=disabled\n'
    printf 'identity_listener=disabled\n'
    printf 'identity_inject_code=disabled\n'
  fi

  if remote_admin_enabled; then
    admin_code="$(http_code_local "https://127.0.0.1:${PIHOLE_REMOTE_HTTPS_PORT}/")"
  else
    admin_code="disabled"
  fi
  printf 'remote_admin_code=%s\n' "${admin_code}"

  if remote_doh_enabled; then
    mode="$(doh_endpoint_mode 2>/dev/null || printf 'native')"
    bare_code="$(http_code_local "https://127.0.0.1:${PIHOLE_REMOTE_HTTPS_PORT}/dns-query")"
    tokenized_code="disabled"
    if doh_mode_requires_token; then
      primary_token="$(primary_doh_token 2>/dev/null || true)"
      if validate_doh_token "${primary_token}"; then
        tokenized_code="$(http_code_local "https://127.0.0.1:${PIHOLE_REMOTE_HTTPS_PORT}/${primary_token}/dns-query")"
      else
        tokenized_code="invalid_token"
      fi
    fi
  else
    mode="disabled"
    bare_code="disabled"
    tokenized_code="disabled"
  fi
  printf 'doh_mode=%s\n' "${mode}"
  printf 'doh_bare_code=%s\n' "${bare_code}"
  printf 'doh_tokenized_code=%s\n' "${tokenized_code}"

  if remote_stack_healthcheck; then
    overall=ok
  else
    overall=fail
  fi
  printf 'remote_healthcheck=%s\n' "${overall}"
  [[ "${overall}" == "ok" ]]
}

core_runtime_healthcheck() {
  local adguard_pid
  adguard_pid="$(pid_from_file "${ADGUARDHOME_PID_FILE}" 2>/dev/null || true)"
  pid_is_running "${adguard_pid}" || return 1
  tcp_listener_local "${PIHOLE_ACTIVE_DNS_PORT}" || return 1
  tcp_listener_local "${PIHOLE_WEB_PORT}" || return 1
  if adguardhome_entered_setup_mode; then
    return 1
  fi
  return 0
}

restart_remote_frontend_proxy() {
  local adguard_pid

  if ! remote_stack_enabled; then
    stop_identity_web_sidecar || true
    stop_remote_nginx || true
    return 0
  fi

  validate_remote_hostname || {
    echo_log "Invalid PIHOLE_REMOTE_HOSTNAME=${PIHOLE_REMOTE_HOSTNAME}"
    return 1
  }
  if remote_dot_enabled; then
    validate_remote_dot_hostname || {
      echo_log "Invalid PIHOLE_REMOTE_DOT_HOSTNAME=${PIHOLE_REMOTE_DOT_HOSTNAME}"
      return 1
    }
  fi
  validate_numeric_ports || {
    echo_log "Invalid numeric remote/listener settings"
    return 1
  }
  validate_doh_mode_and_token || return 1

  sync_runtime_secrets
  write_remote_runtime_env_file
  ensure_remote_tls || return 1

  record_frontend_reload "remote-reload-frontend"

  if remote_frontend_via_nginx; then
    adguard_pid="$(pid_from_file "${ADGUARDHOME_PID_FILE}" 2>/dev/null || true)"
    if ! pid_is_running "${adguard_pid}" || ! tcp_listener_local "${PIHOLE_WEB_PORT}"; then
      echo_log "AdGuardHome web listener unavailable; cannot reload nginx frontend without runtime restart"
      return 1
    fi
    start_identity_web_sidecar || return 1
    start_remote_nginx || return 1
  fi

  remote_stack_healthcheck || return 1
  return 0
}

restart_remote_frontend_components() {
  if ! remote_stack_enabled; then
    stop_remote_watchdog || true
    stop_identity_web_sidecar || true
    stop_remote_nginx || true
    return 0
  fi

  record_frontend_reload "runtime-restart-services"
  stop_remote_watchdog || true
  stop_identity_web_sidecar || true
  stop_remote_nginx || true
  prepare_runtime || return 1
  launch_remote_frontend || return 1
  start_remote_watchdog || true
  remote_stack_healthcheck || return 1
  return 0
}

restart_runtime_sidecars() {
  restart_remote_frontend_components || return 1
  return 0
}

restart_runtime_core_and_frontend() {
  record_frontend_reload "runtime-restart-core"
  stop_remote_watchdog || true
  stop_identity_web_sidecar || true
  stop_remote_nginx || true
  prepare_runtime || return 1
  stop_adguardhome_core || true
  launch_adguardhome_core || return 1
  launch_remote_frontend || return 1
  start_remote_watchdog || true
  remote_stack_healthcheck || return 1
  return 0
}

run_migration_import_if_present() {
  if [[ -f "${PIHOLE_REMOTE_MIGRATION_DONE_FILE}" ]]; then
    return 0
  fi
  if [[ ! -r "${PIHOLE_REMOTE_MIGRATION_PAYLOAD_FILE}" ]]; then
    return 0
  fi
  if [[ ! -x "${PIHOLE_REMOTE_MIGRATION_HELPER}" ]]; then
    echo_log "migration payload present but helper missing: ${PIHOLE_REMOTE_MIGRATION_HELPER}"
    return 1
  fi
  if ! command -v python3 >/dev/null 2>&1; then
    echo_log "migration payload present but python3 is unavailable"
    return 1
  fi

  local password
  password="$(adguard_admin_password 2>/dev/null || true)"
  if [[ -z "${password}" ]]; then
    echo_log "migration payload present but admin password is unavailable"
    return 1
  fi

  local migration_base_url
  migration_base_url="http://127.0.0.1:${PIHOLE_WEB_PORT}"

  echo_log "Running one-time Pi-hole -> AdGuard migration import"
  set +e
  python3 "${PIHOLE_REMOTE_MIGRATION_HELPER}" \
    --base-url "${migration_base_url}" \
    --username "${ADGUARDHOME_ADMIN_USERNAME}" \
    --password-file "${PIHOLE_REMOTE_ADMIN_PASSWORD_SECRET_FILE}" \
    --payload-file "${PIHOLE_REMOTE_MIGRATION_PAYLOAD_FILE}" \
    --report-file "${PIHOLE_REMOTE_MIGRATION_REPORT_FILE}" >> "${ADGUARDHOME_LOG_DIR}/migration.log" 2>&1
  local rc=$?
  set -e
  if [[ "${rc}" -ne 0 ]]; then
    echo_log "migration import failed (rc=${rc})"
    return 1
  fi

  touch "${PIHOLE_REMOTE_MIGRATION_DONE_FILE}"
  chmod 600 "${PIHOLE_REMOTE_MIGRATION_DONE_FILE}" || true
  return 0
}

runtime_status_summary() {
  local adguard_pid watchdog_pid identity_web_pid
  adguard_pid="$(pid_from_file "${ADGUARDHOME_PID_FILE}" 2>/dev/null || true)"
  watchdog_pid="$(pid_from_file "${PIHOLE_REMOTE_WATCHDOG_PID_FILE}" 2>/dev/null || true)"
  identity_web_pid="$(pid_from_file "${PIHOLE_REMOTE_DOH_IDENTITY_WEB_PID_FILE}" 2>/dev/null || true)"

  echo_log "status:adguardhome pid=${adguard_pid:-none} alive=$(pid_is_running "${adguard_pid}" && echo yes || echo no)"
  echo_log "status:watchdog pid=${watchdog_pid:-none} alive=$(pid_is_running "${watchdog_pid}" && echo yes || echo no)"
  if remote_frontend_via_nginx; then
    echo_log "status:identity_web pid=${identity_web_pid:-none} alive=$(pid_is_running "${identity_web_pid}" && echo yes || echo no)"
  fi
  echo_log "status:listen_dns :${PIHOLE_ACTIVE_DNS_PORT} $(tcp_listener_local "${PIHOLE_ACTIVE_DNS_PORT}" && echo up || echo down)"
  echo_log "status:listen_web :${PIHOLE_WEB_PORT} $(tcp_listener_local "${PIHOLE_WEB_PORT}" && echo up || echo down)"
  if remote_stack_enabled; then
    echo_log "status:listen_https :${PIHOLE_REMOTE_HTTPS_PORT} $(tcp_listener_local "${PIHOLE_REMOTE_HTTPS_PORT}" && echo up || echo down)"
    if remote_dot_enabled; then
      echo_log "status:listen_dot :${PIHOLE_REMOTE_DOT_PORT} $(tcp_listener_local "${PIHOLE_REMOTE_DOT_PORT}" && echo up || echo down)"
    fi
  fi
}

run_mode="start"
if (( $# > 0 )); then
  case "$1" in
    --prepare-runtime)
      run_mode="prepare-runtime"
      ;;
    --launch-core)
      run_mode="launch-core"
      ;;
    --launch-frontend)
      run_mode="launch-frontend"
      ;;
    --start-watchdog)
      run_mode="start-watchdog"
      ;;
    --run-migration-import)
      run_mode="run-migration-import"
      ;;
    --remote-healthcheck)
      run_mode="remote-healthcheck"
      ;;
    --remote-healthcheck-debug)
      run_mode="remote-healthcheck-debug"
      ;;
    --core-healthcheck)
      run_mode="core-healthcheck"
      ;;
    --remote-restart)
      run_mode="remote-restart"
      ;;
    --runtime-restart-services)
      run_mode="runtime-restart-services"
      ;;
    --runtime-restart-core)
      run_mode="runtime-restart-core"
      ;;
    --remote-reload-frontend)
      run_mode="remote-reload-frontend"
      ;;
    --runtime-status)
      run_mode="runtime-status"
      ;;
    *)
      echo_log "Unknown adguardhome-start mode: $1"
      exit 2
      ;;
  esac
fi

case "${run_mode}" in
  remote-healthcheck|remote-healthcheck-debug|core-healthcheck|remote-restart|runtime-restart-services|runtime-restart-core|remote-reload-frontend|runtime-status)
    load_remote_runtime_env
    ;;
esac

case "${run_mode}" in
  start|prepare-runtime|launch-core|launch-frontend|remote-restart|runtime-restart-services|runtime-restart-core|remote-reload-frontend)
    acquire_mutation_lock || exit 1
    trap 'release_mutation_lock' EXIT
    ;;
esac

case "${run_mode}" in
  remote-healthcheck)
    remote_stack_healthcheck
    exit $?
    ;;
  remote-healthcheck-debug)
    remote_stack_healthcheck_debug
    exit $?
    ;;
  core-healthcheck)
    core_runtime_healthcheck
    exit $?
    ;;
  prepare-runtime)
    prepare_runtime
    exit $?
    ;;
  launch-core)
    launch_adguardhome_core
    exit $?
    ;;
  launch-frontend)
    launch_remote_frontend
    exit $?
    ;;
  start-watchdog)
    start_remote_watchdog
    exit $?
    ;;
  run-migration-import)
    run_migration_import_if_present
    exit $?
    ;;
  remote-restart)
    restart_remote_frontend_components
    start_remote_watchdog || true
    remote_stack_healthcheck
    exit $?
    ;;
  runtime-restart-services)
    restart_runtime_sidecars
    remote_stack_healthcheck
    exit $?
    ;;
  runtime-restart-core)
    restart_runtime_core_and_frontend
    remote_stack_healthcheck
    exit $?
    ;;
  remote-reload-frontend)
    restart_remote_frontend_proxy
    exit $?
    ;;
  runtime-status)
    runtime_status_summary
    exit 0
    ;;
  start)
    ;;
  *)
    echo_log "Unhandled adguardhome-start mode: ${run_mode}"
    exit 2
    ;;
esac

cleanup_on_exit() {
  release_mutation_lock
}
trap cleanup_on_exit EXIT

start_adguardhome
start_remote_watchdog || true
run_migration_import_if_present || {
  echo_log "WARN: migration import did not complete"
}
runtime_status_summary

adguard_pid="$(pid_from_file "${ADGUARDHOME_PID_FILE}" 2>/dev/null || true)"
if ! pid_is_running "${adguard_pid}"; then
  echo_log "AdGuardHome pid missing after startup"
  exit 1
fi

exit 0
