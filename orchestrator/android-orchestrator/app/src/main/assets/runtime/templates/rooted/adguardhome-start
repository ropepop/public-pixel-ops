ensure_proc_self_exe_available() {
  if [[ -e /proc/self/exe ]]; then
    return 0
  fi

  echo_log "Missing /proc/self/exe in chroot; attempting local procfs remount"
  if ! command -v mount >/dev/null 2>&1; then
    echo_log "mount command unavailable in chroot; cannot repair /proc"
    return 1
  fi

  umount /proc >/dev/null 2>&1 || true
  mkdir -p /proc >/dev/null 2>&1 || true
  mount -t proc proc /proc >/dev/null 2>&1 || true
  if [[ -e /proc/self/exe ]]; then
    return 0
  fi

  echo_log "Failed to repair /proc/self/exe in chroot"
  return 1
}

