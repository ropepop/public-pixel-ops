install_adguardhome_binary() {
  local tmp_dir archive extracted_bin curl_rc

  if ! command -v curl >/dev/null 2>&1; then
    echo_log "cannot auto-install AdGuardHome: curl is unavailable"
    return 1
  fi
  if ! command -v tar >/dev/null 2>&1; then
    echo_log "cannot auto-install AdGuardHome: tar is unavailable"
    return 1
  fi

  tmp_dir="$(mktemp -d)"
  archive="${tmp_dir}/adguardhome-linux-arm64.tar.gz"
  extracted_bin=""
  curl_rc=0

  set +e
  curl -fL --retry 2 --connect-timeout 10 --max-time 180 \
    -o "${archive}" "${ADGUARDHOME_RELEASE_URL}" >> "${ADGUARDHOME_RUNTIME_LOG_FILE}" 2>&1
  curl_rc=$?
  set -e
  if [[ "${curl_rc}" -ne 0 ]]; then
    echo_log "failed to download AdGuardHome release from ${ADGUARDHOME_RELEASE_URL} (rc=${curl_rc})"
    rm -rf "${tmp_dir}"
    return 1
  fi

  if ! tar -xzf "${archive}" -C "${tmp_dir}" >/dev/null 2>&1; then
    echo_log "failed to extract downloaded AdGuardHome archive"
    rm -rf "${tmp_dir}"
    return 1
  fi

  extracted_bin="$(find "${tmp_dir}" -type f -name 'AdGuardHome' | head -n1 || true)"
  if [[ -z "${extracted_bin}" || ! -x "${extracted_bin}" ]]; then
    echo_log "downloaded archive did not contain executable AdGuardHome binary"
    rm -rf "${tmp_dir}"
    return 1
  fi

  mkdir -p "${ADGUARDHOME_INSTALL_DIR}" "${ADGUARDHOME_WORK_DIR}" "${ADGUARDHOME_CONF_DIR}"
  install -m 0755 "${extracted_bin}" "${ADGUARDHOME_INSTALL_DIR}/AdGuardHome"
  rm -rf "${tmp_dir}"
  return 0
}

