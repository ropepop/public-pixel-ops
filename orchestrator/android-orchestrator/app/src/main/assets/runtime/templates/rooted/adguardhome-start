ensure_doh_identity_store() {
  local mode legacy_token
  mode="$(doh_endpoint_mode 2>/dev/null || true)"
  if [[ -z "${mode}" ]]; then
    echo_log "Invalid ADGUARDHOME_REMOTE_DOH_ENDPOINT_MODE=${ADGUARDHOME_REMOTE_DOH_ENDPOINT_MODE}"
    return 1
  fi

  if ! remote_doh_enabled && ! remote_dot_identity_enabled; then
    return 0
  fi
  if ! remote_doh_enabled && remote_dot_identity_enabled && ! remote_dot_enabled; then
    echo_log "DoT identity mode requires PIHOLE_REMOTE_DOT_ENABLED=1"
    return 1
  fi
  if ! remote_doh_enabled && ! doh_mode_requires_token && ! remote_dot_identity_enabled; then
    return 0
  fi
  if ! identityctl_available; then
    echo_log "Managed DNS identities require ${PIHOLE_REMOTE_DOH_IDENTITYCTL}, but it is missing"
    return 1
  fi

  legacy_token="$(printf '%s' "${ADGUARDHOME_REMOTE_DOH_PATH_TOKEN}" | tr -d '\r\n[:space:]')"
  if remote_doh_enabled && doh_mode_requires_token && [[ -n "${legacy_token}" ]]; then
    if ! identityctl ensure-legacy --legacy-token "${legacy_token}" --id default >/dev/null 2>&1; then
      echo_log "Failed to import legacy ADGUARDHOME_REMOTE_DOH_PATH_TOKEN into identity store"
      return 1
    fi
  else
    if ! identityctl ensure-store >/dev/null 2>&1; then
      echo_log "Failed to initialize DoH identity store at ${PIHOLE_REMOTE_DOH_IDENTITIES_FILE}"
      return 1
    fi
  fi

  if remote_dot_identity_enabled; then
    if ! identityctl ensure-dot-labels >/dev/null 2>&1; then
      echo_log "Failed to ensure DoT identity labels in ${PIHOLE_REMOTE_DOH_IDENTITIES_FILE}"
      return 1
    fi
  fi

  if remote_doh_enabled && doh_mode_requires_token && ! identityctl validate-active >/dev/null 2>&1; then
    echo_log "DoH identity store validation failed for tokenized mode"
    return 1
  fi
  return 0
}

