is_true() {
  case "${1:-}" in
    1|true|TRUE|yes|YES|on|ON) return 0 ;;
    *) return 1 ;;
  esac
}

is_valid_ipv4() {
  local ip="${1:-}"
  local o1 o2 o3 o4 octet
  [[ "${ip}" =~ ^([0-9]{1,3}[.]){3}[0-9]{1,3}$ ]] || return 1
  IFS='.' read -r o1 o2 o3 o4 <<<"${ip}"
  for octet in "${o1}" "${o2}" "${o3}" "${o4}"; do
    [[ "${octet}" =~ ^[0-9]{1,3}$ ]] || return 1
    (( octet >= 0 && octet <= 255 )) || return 1
  done
  return 0
}

router_public_ip_attribution_enabled() {
  is_true "${ADGUARDHOME_REMOTE_ROUTER_PUBLIC_IP_ATTRIBUTION_ENABLED}"
}

ddns_last_ipv4() {
  local value path
  for path in "${PIHOLE_DDNS_LAST_IPV4_FILE}" "${PIHOLE_DDNS_LAST_IPV4_FALLBACK_FILE}"; do
    [[ -r "${path}" ]] || continue
    value="$(tr -d '\r\n[:space:]' < "${path}" 2>/dev/null || true)"
    if is_valid_ipv4 "${value}"; then
      printf '%s\n' "${value}"
      return 0
    fi
  done
  return 1
}

ts() { date '+%Y-%m-%dT%H:%M:%S%z'; }
echo_log() { printf '[%s] %s\n' "$(ts)" "$*" >&2; }

load_remote_runtime_env() {
  if [[ -r "${PIHOLE_REMOTE_RUNTIME_ENV_FILE}" ]]; then
    # shellcheck disable=SC1090
    set -a
    . "${PIHOLE_REMOTE_RUNTIME_ENV_FILE}"
    set +a
  fi
}

pid_is_running() {
  local pid="${1:-}"
  [[ -n "${pid}" ]] && kill -0 "${pid}" >/dev/null 2>&1
}

pid_from_file() {
  local file="$1"
  [[ -f "${file}" ]] || return 1
  local pid
  pid="$(cat "${file}" 2>/dev/null || true)"
  [[ "${pid}" =~ ^[0-9]+$ ]] || return 1
  printf '%s\n' "${pid}"
}

wait_for_pidfile_process() {
  local file="$1"
  local timeout_ms="${2:-15000}"
  local step_ms=250
  local elapsed_ms=0
  local pid=""

  while (( elapsed_ms < timeout_ms )); do
    pid="$(pid_from_file "${file}" 2>/dev/null || true)"
    if pid_is_adguardhome_process "${pid}"; then
      printf '%s\n' "${pid}"
      return 0
    fi
    sleep 0.25
    elapsed_ms=$((elapsed_ms + step_ms))
  done
  return 1
}

emit_runtime_attempt_excerpt() {
  local start_line="${1:-0}"
  local attempt_log_file="$2"
  local max_lines="${3:-60}"
  local captured=0
  local line=""
  local excerpt_file=""

  if [[ ! -f "${ADGUARDHOME_RUNTIME_LOG_FILE}" ]]; then
    echo_log "runtime log missing: ${ADGUARDHOME_RUNTIME_LOG_FILE}"
    return 0
  fi

  excerpt_file="$(mktemp)"
  awk -v start="${start_line}" 'NR > start' "${ADGUARDHOME_RUNTIME_LOG_FILE}" 2>/dev/null | tail -n "${max_lines}" > "${excerpt_file}" || true
  while IFS= read -r line; do
    [[ -n "${line}" ]] || continue
    captured=$((captured + 1))
    printf '%s\n' "${line}" >> "${attempt_log_file}"
    echo_log "runtime-attempt: ${line}"
  done < "${excerpt_file}"
  rm -f "${excerpt_file}" >/dev/null 2>&1 || true

  if (( captured == 0 )); then
    echo_log "No new runtime log lines captured for this start attempt"
  fi
}

pid_is_adguardhome_process() {
  local pid="${1:-}"
  local cmdline=""
  [[ -n "${pid}" ]] || return 1
  pid_is_running "${pid}" || return 1
  cmdline="$(pid_cmdline "${pid}" 2>/dev/null || true)"
  [[ "${cmdline}" == *"AdGuardHome"* ]]
}

kill_pidfile() {
  local file="$1"
  local pid=""
  pid="$(pid_from_file "${file}" 2>/dev/null || true)"
  if pid_is_running "${pid}"; then
    kill "${pid}" >/dev/null 2>&1 || true
    sleep 1
    kill -9 "${pid}" >/dev/null 2>&1 || true
  fi
  rm -f "${file}"
}

write_state_file() {
  local file="$1"
  local value="${2:-}"
  local tmpfile=""

  mkdir -p "$(dirname "${file}")"
  tmpfile="$(mktemp "${file}.XXXXXX")"
  printf '%s\n' "${value}" > "${tmpfile}"
  chmod 600 "${tmpfile}" >/dev/null 2>&1 || true
  mv -f "${tmpfile}" "${file}"
}

read_state_int() {
  local file="$1"
  local value=""
  [[ -r "${file}" ]] || return 1
  value="$(tr -d '\r\n[:space:]' < "${file}" 2>/dev/null || true)"
  [[ "${value}" =~ ^[0-9]+$ ]] || return 1
  printf '%s\n' "${value}"
}

record_frontend_reload() {
  local reason="$1"
  local now_epoch previous_epoch stable_runtime count

  now_epoch="$(date +%s)"
  previous_epoch="$(read_state_int "${PIHOLE_REMOTE_FRONTEND_LAST_RELOAD_EPOCH_FILE}" 2>/dev/null || true)"
  if [[ -n "${previous_epoch}" ]]; then
    stable_runtime=$((now_epoch - previous_epoch))
    if (( stable_runtime < 0 )); then
      stable_runtime=0
    fi
    write_state_file "${PIHOLE_REMOTE_FRONTEND_LAST_STABLE_RUNTIME_SEC_FILE}" "${stable_runtime}"
  fi

  count="$(read_state_int "${PIHOLE_REMOTE_FRONTEND_RESTART_COUNT_FILE}" 2>/dev/null || printf '0')"
  count=$((count + 1))
  write_state_file "${PIHOLE_REMOTE_FRONTEND_RESTART_COUNT_FILE}" "${count}"

  previous_epoch="$(read_state_int "${PIHOLE_REMOTE_FRONTEND_RESTART_WINDOW_EPOCH_FILE}" 2>/dev/null || true)"
  if [[ -z "${previous_epoch}" ]] || (( now_epoch - previous_epoch >= 3600 )); then
    write_state_file "${PIHOLE_REMOTE_FRONTEND_RESTART_WINDOW_EPOCH_FILE}" "${now_epoch}"
    write_state_file "${PIHOLE_REMOTE_FRONTEND_RESTART_COUNT_1H_FILE}" "1"
  else
    count="$(read_state_int "${PIHOLE_REMOTE_FRONTEND_RESTART_COUNT_1H_FILE}" 2>/dev/null || printf '0')"
    count=$((count + 1))
    write_state_file "${PIHOLE_REMOTE_FRONTEND_RESTART_COUNT_1H_FILE}" "${count}"
  fi

  write_state_file "${PIHOLE_REMOTE_FRONTEND_LAST_RELOAD_REASON_FILE}" "${reason}"
  write_state_file "${PIHOLE_REMOTE_FRONTEND_LAST_RELOAD_EPOCH_FILE}" "${now_epoch}"
}

tcp_listener_local() {
  local port="$1"
  local port_hex
  if command -v nc >/dev/null 2>&1; then
    nc -z -w 1 127.0.0.1 "${port}" >/dev/null 2>&1
    return $?
  fi
  if command -v ss >/dev/null 2>&1; then
    ss -H -ltn 2>/dev/null | awk '{print $4}' | grep -Eq "[:.]${port}\$"
    return $?
  fi
  if [[ "${port}" =~ ^[0-9]+$ ]] && (( port >= 1 && port <= 65535 )); then
    port_hex="$(printf '%04X' "${port}")"
    for proc_file in /proc/net/tcp /proc/net/tcp6; do
      [[ -r "${proc_file}" ]] || continue
      if awk -v want="${port_hex}" '
        NR > 1 {
          split($2, local_addr, ":")
          if (local_addr[2] == want && $4 == "0A") {
            found = 1
            exit 0
          }
        }
        END { exit(found ? 0 : 1) }
      ' "${proc_file}" >/dev/null 2>&1; then
        return 0
      fi
    done
  fi
  return 1
}

listener_pids_for_port() {
  local port="$1"
  if ! command -v ss >/dev/null 2>&1; then
    return 0
  fi
  ss -H -ltnp 2>/dev/null | awk -v p="${port}" '
    {
      addr=$4
      if (addr ~ "\\]:" p "$" || addr ~ ":" p "$") {
        print $0
      }
    }
  ' | sed -n 's/.*pid=\([0-9][0-9]*\).*/\1/p' | sort -u
}

pid_cmdline() {
  local pid="${1:-}"
  [[ -n "${pid}" ]] || return 1
  if [[ -r "/proc/${pid}/cmdline" ]]; then
    tr '\000' ' ' < "/proc/${pid}/cmdline" 2>/dev/null || true
    return 0
  fi
  return 1
}

mutation_lock_owner_active() {
  local pid="${1:-}" cmdline=""
  [[ -n "${pid}" ]] || return 1
  pid_is_running "${pid}" || return 1
  cmdline="$(pid_cmdline "${pid}" 2>/dev/null || true)"
  [[ "${cmdline}" == *"adguardhome-start"* ]]
}

acquire_mutation_lock() {
  local pid="" waited_ms=0
  local timeout_ms=30000

  if (( MUTATION_LOCK_HELD == 1 )); then
    return 0
  fi

  while true; do
    if mkdir "${ADGUARDHOME_MUTATION_LOCK_DIR}" >/dev/null 2>&1; then
      printf '%s\n' "$$" > "${ADGUARDHOME_MUTATION_LOCK_PID_FILE}"
      chmod 600 "${ADGUARDHOME_MUTATION_LOCK_PID_FILE}" >/dev/null 2>&1 || true
      MUTATION_LOCK_HELD=1
      return 0
    fi

    pid="$(pid_from_file "${ADGUARDHOME_MUTATION_LOCK_PID_FILE}" 2>/dev/null || true)"
    if ! mutation_lock_owner_active "${pid}"; then
      rm -f "${ADGUARDHOME_MUTATION_LOCK_PID_FILE}" >/dev/null 2>&1 || true
      rmdir "${ADGUARDHOME_MUTATION_LOCK_DIR}" >/dev/null 2>&1 || true
      continue
    fi

    if (( waited_ms >= timeout_ms )); then
      echo_log "Timed out waiting for AdGuardHome mutation lock (owner_pid=${pid:-unknown})"
      return 1
    fi

    sleep 0.25
    waited_ms=$((waited_ms + 250))
  done
}

release_mutation_lock() {
  if (( MUTATION_LOCK_HELD == 0 )); then
    return 0
  fi
  rm -f "${ADGUARDHOME_MUTATION_LOCK_PID_FILE}" >/dev/null 2>&1 || true
  rmdir "${ADGUARDHOME_MUTATION_LOCK_DIR}" >/dev/null 2>&1 || true
  MUTATION_LOCK_HELD=0
}

config_password_hash_from_file() {
  local file="${1:-}"
  [[ -r "${file}" ]] || return 1
  sed -n 's/^[[:space:]]*password:[[:space:]]*"\?\(\$2[aby]\$[0-9][0-9]\$[^"]*\)"\?/\1/p' "${file}" | head -n1
}

yaml_top_level_block_from_file() {
  local file="${1:-}" key="${2:-}"
  [[ -r "${file}" && -n "${key}" ]] || return 1
  awk -v key="${key}" '
    BEGIN { in_block=0 }
    function is_top_level_key(line) {
      return line ~ /^[A-Za-z_][A-Za-z0-9_]*:[[:space:]]*([^[:space:]].*)?$/
    }
    {
      if ($0 ~ ("^" key ":[[:space:]]*($|[^[:space:]].*)$")) {
        in_block=1
      } else if (in_block && is_top_level_key($0)) {
        exit
      }
      if (in_block) {
        print
      }
    }
  ' "${file}"
}

preserved_yaml_top_level_block() {
  local key="${1:-}" file="" block=""
  [[ -n "${key}" ]] || return 1
  for file in "${ADGUARDHOME_CONFIG_FILE}" "${ADGUARDHOME_CONFIG_LAST_GOOD_FILE}"; do
    block="$(yaml_top_level_block_from_file "${file}" "${key}" 2>/dev/null || true)"
    if [[ -n "${block}" ]]; then
      printf '%s\n' "${block}"
      return 0
    fi
  done
  return 1
}

existing_schema_version() {
  local file="" version=""
  for file in "${ADGUARDHOME_CONFIG_FILE}" "${ADGUARDHOME_CONFIG_LAST_GOOD_FILE}"; do
    [[ -r "${file}" ]] || continue
    version="$(sed -n 's/^schema_version:[[:space:]]*\([0-9][0-9]*\)[[:space:]]*$/\1/p' "${file}" | head -n1)"
    if [[ "${version}" =~ ^[0-9]+$ ]]; then
      printf '%s\n' "${version}"
      return 0
    fi
  done
  printf '28\n'
}

render_preserved_adguardhome_dynamic_blocks() {
  local key="" block="" rendered=0
  for key in filtering filters whitelist_filters user_rules; do
    block="$(preserved_yaml_top_level_block "${key}" 2>/dev/null || true)"
    [[ -n "${block}" ]] || continue
    printf '%s\n\n' "${block}"
    rendered=1
  done
  [[ "${rendered}" -eq 1 ]]
}

expected_web_bind_address() {
  if remote_frontend_via_nginx; then
    printf '127.0.0.1:%s\n' "${PIHOLE_WEB_PORT}"
  else
    printf '0.0.0.0:%s\n' "${PIHOLE_WEB_PORT}"
  fi
}

validate_rendered_config() {
  local file="${1:-}" expected_web_bind=""
  [[ -n "${file}" ]] || return 1
  [[ -s "${file}" ]] || {
    echo_log "Rendered AdGuardHome config is empty: ${file}"
    return 1
  }

  expected_web_bind="$(expected_web_bind_address)"
  grep -Fq 'http:' "${file}" || {
    echo_log "Rendered AdGuardHome config missing http block: ${file}"
    return 1
  }
  grep -Fq "address: ${expected_web_bind}" "${file}" || {
    echo_log "Rendered AdGuardHome config missing expected web bind ${expected_web_bind}: ${file}"
    return 1
  }
  grep -Fq "port: ${PIHOLE_ACTIVE_DNS_PORT}" "${file}" || {
    echo_log "Rendered AdGuardHome config missing expected DNS port ${PIHOLE_ACTIVE_DNS_PORT}: ${file}"
    return 1
  }
  grep -Eq '^schema_version:[[:space:]]*[0-9]+$' "${file}" || {
    echo_log "Rendered AdGuardHome config missing schema_version marker: ${file}"
    return 1
  }
  grep -Fq 'clients:' "${file}" || {
    echo_log "Rendered AdGuardHome config missing clients block: ${file}"
    return 1
  }
  grep -Fq 'persistent:' "${file}" || {
    echo_log "Rendered AdGuardHome config missing persistent clients block: ${file}"
    return 1
  }
  grep -Fq 'name: "Loopback internal"' "${file}" || {
    echo_log "Rendered AdGuardHome config missing loopback suppression client: ${file}"
    return 1
  }
  grep -Fq '      - 127.0.0.1' "${file}" || {
    echo_log "Rendered AdGuardHome config missing IPv4 loopback suppression entry: ${file}"
    return 1
  }
  grep -Fq '      - ::1' "${file}" || {
    echo_log "Rendered AdGuardHome config missing IPv6 loopback suppression entry: ${file}"
    return 1
  }
  grep -Fq '    ignore_querylog: true' "${file}" || {
    echo_log "Rendered AdGuardHome config missing loopback querylog suppression flag: ${file}"
    return 1
  }
  grep -Fq '    ignore_statistics: true' "${file}" || {
    echo_log "Rendered AdGuardHome config missing loopback statistics suppression flag: ${file}"
    return 1
  }

  if remote_admin_enabled; then
    grep -Fq "name: \"${ADGUARDHOME_ADMIN_USERNAME}\"" "${file}" || {
      echo_log "Rendered AdGuardHome config missing admin user ${ADGUARDHOME_ADMIN_USERNAME}: ${file}"
      return 1
    }
    if ! config_password_hash_from_file "${file}" >/dev/null 2>&1; then
      echo_log "Rendered AdGuardHome config missing admin password hash while remote admin is enabled"
      return 1
    fi
  fi

  return 0
}

