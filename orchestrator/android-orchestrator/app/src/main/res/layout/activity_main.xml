<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:fillViewport="true">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
      android:id="@+id/title"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="Pixel Root Orchestrator"
      android:textSize="22sp"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/subtitle"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="6dp"
      android:text="Boot, supervise, observe, and recover rooted Pi-hole + SSH + VPN"
      android:textSize="14sp" />

    <Button
      android:id="@+id/bootstrapButton"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="16dp"
      android:text="Bootstrap + Cutover" />

    <Button
      android:id="@+id/startAllButton"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:text="Start All" />

    <Button
      android:id="@+id/stopAllButton"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:text="Stop All" />

    <Button
      android:id="@+id/healthButton"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:text="Run Health Check" />

    <Button
      android:id="@+id/ddnsButton"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:text="Sync DDNS Now" />

    <Button
      android:id="@+id/exportButton"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="8dp"
      android:text="Export Support Bundle" />

    <TextView
      android:id="@+id/statusText"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="16dp"
      android:textIsSelectable="true"
      android:textSize="13sp" />
  </LinearLayout>

</ScrollView>
